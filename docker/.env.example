# =============================================================================
#  Baby Care Tracker Web - 部署环境变量模板
#  使用：cp docker/.env.example docker/.env && vi docker/.env
#  注意：.env 不要进 git！务必加入 .gitignore
# =============================================================================

# 镜像 registry（CI 自动渲染为 TCR 完整路径；本机 deploy.sh 默认使用本地镜像名）
# - GitHub Actions 部署：deploy.yml 会覆盖为 ccr.ccs.tencentyun.com/merlinjc/baby-care-tracker-3
# - 本机 scripts/deploy.sh：保持 baby-care-tracker-web，走 docker save → scp → load
IMAGE_REGISTRY=ccr.ccs.tencentyun.com/merlinjc/baby-care-tracker-3
# 镜像 tag（CI 推送的 commit short sha 或 release 版本号）
IMAGE_TAG=latest

# ---- 数据库 ----
# SQLite（默认，零依赖；持久化在 docker volume server_data）
DATABASE_URL=file:/app/data/prod.db
# 切换 MySQL 时改为：
# DATABASE_URL=mysql://baby:STRONG_PASS@mysql:3306/baby_care?connection_limit=10

# ---- JWT 密钥（必填）----
# 生成：openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_STRING

# ---- CORS 白名单 ----
# 生产环境建议指定具体域名，开发期可设 *
CORS_ORIGIN=*

# ---- AI（OpenAI 兼容，默认 TokenHub · hy3-preview；未配置时 AI 功能降级）----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_MODEL=hy3-preview
AI_DAILY_QUOTA=100
AI_FETCH_TIMEOUT_MS=30000

# ---- 巡检任务 ----
PATROL_ENABLED=false

# ---- 部署相关（仅 deploy.sh 使用，不会注入容器） ----
DEPLOY_HOST=152.136.125.185
DEPLOY_USER=root
DEPLOY_PATH=/opt/baby-care
SSH_KEY_PATH=./BJ_Baby_Care_Tracker.pem
