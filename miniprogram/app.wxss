/**app.wxss - 美拉德色彩风格**/
page {
  /* 主色调 - 美拉德色系 */
  --primary-color: #D4B896;        /* 暖杏色 */
  --primary-light: #E8DCC8;        /* 米白 */
  --primary-dark: #8B7B6B;         /* 深棕 */
  
  /* 强调色 */
  --accent-color: #B8D4B8;         /* 薄荷绿 */
  
  /* 功能色 */
  --feeding-color: #A8D4A8;        /* 浅绿 - 喂养 */
  --sleep-color: #B8A8D4;          /* 淡紫（低饱和） - 睡眠 */
  --diaper-color: #D4C8A8;         /* 浅棕 - 排便 */
  --temperature-color: #D4A8A8;    /* 浅红 - 体温 */
  
  /* 语义功能色 */
  --success-color: #7BC950;        /* 成功/完成 - 柔和绿 */
  --danger-color: #E85454;         /* 危险/逾期 - 柔和红 */
  --warning-color: #D4883D;        /* 警告/待处理 - 暖橙 */
  --info-color: #7BA3C9;           /* 信息/提示 - 柔和蓝 */

  /* 语义背景色 */
  --warning-bg: #FFF5EB;           /* 警告/选中背景 - 暖橙浅色 */
  --danger-bg: #FFF5F5;            /* 危险背景 - 浅红 */

  /* 渐变色 */
  --success-gradient: linear-gradient(135deg, #7BC950, #A8D88A);  /* 成功渐变 */
  --danger-gradient: linear-gradient(135deg, #E85454, #F5A9A9);   /* 危险渐变 */

  /* 文字色 */
  --text-primary: #3D3D3D;         /* 主要文字 */
  --text-secondary: #666666;       /* 次要文字 */
  --text-hint: #999999;            /* 辅助文字 */
  --text-tertiary: #999999;        /* 三级文字 - 兼容旧变量名 */
  --text-color: #3D3D3D;           /* 文字色 - 兼容旧变量名 */
  
  /* 背景色 */
  --bg-primary: #F5F1EB;           /* 主背景 */
  --bg-secondary: #FFFFFF;         /* 次级背景 - 卡片 */
  --bg-card: #FFFFFF;
  --background-light: #F5F1EB;     /* 浅背景 - 兼容旧变量名 */
  --background: #F5F1EB;           /* 背景 - 兼容旧变量名 */
  
  /* 间距 - 8px基础网格系统 */
  --spacing-xs: 8rpx;              /* 极小间距 */
  --spacing-sm: 16rpx;             /* 小间距 */
  --spacing-md: 24rpx;             /* 中等间距 */
  --spacing-lg: 32rpx;             /* 大间距 */
  --spacing-xl: 48rpx;             /* 超大间距 */
  --spacing-xxl: 64rpx;            /* 巨大间距 */
  
  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  
  /* 阴影 */
  --shadow-card: 0 4rpx 24rpx rgba(139, 123, 107, 0.08);
  --shadow-soft: 0 4rpx 16rpx rgba(139, 123, 107, 0.06);
  --shadow-popup: 0 8rpx 48rpx rgba(139, 123, 107, 0.12);
  
  /* 过渡 */
  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
  
  /* 遮罩色 */
  --mask-color: rgba(139, 123, 107, 0.4);
  --mask-color-dark: rgba(61, 52, 39, 0.6);
  
  /* 渐变终止色 */
  --gradient-end: #C4A878;          /* 按钮渐变终止色 */
  --disabled-start: #D4C8B8;       /* 禁用态渐变起始 */
  --disabled-end: #C8B8A8;         /* 禁用态渐变终止 */
  
  /* 功能色渐变背景 */
  --feeding-bg: linear-gradient(135deg, #E8F4E8 0%, #D4E8D4 100%);
  --sleep-bg: linear-gradient(135deg, #E8E4F4 0%, #D4D0E8 100%);
  --diaper-bg: linear-gradient(135deg, #F4F0E8 0%, #E8E4D4 100%);
  --temperature-bg: linear-gradient(135deg, #F4E8E8 0%, #E8D4D4 100%);
  
  /* 其他 */
  --white: #FFFFFF;
  --border-color: rgba(139, 123, 107, 0.1);
  
  /* 语义扩展变量（Phase 4 新增） */
  --text-warm-brown: #6B5A4E;          /* 温暖棕色文字 */
  --accent-warm: #C49A6C;              /* 暖色强调 */
  --bg-hover: rgba(212, 184, 150, 0.08); /* 悬停背景 */
  --border-warm: rgba(196, 154, 108, 0.2); /* 温暖边框 */
  --percentile-normal-bg: rgba(123, 201, 80, 0.1); /* 正常百分位背景 */
  --percentile-normal-text: #5A9A3A;   /* 正常百分位文字 */
  --percentile-abnormal-bg: rgba(232, 84, 84, 0.1); /* 异常百分位背景 */
  --percentile-abnormal-text: #C45050; /* 异常百分位文字 */

  /* 发热等级色（PRE-3 新增） */
  --fever-low: #5B8FF9;
  --fever-normal: #07C160;
  --fever-low-fever: #FFC53D;
  --fever-moderate: #FF976A;
  --fever-high: #FF7875;
  --fever-ultra-high: #FF4D4F;

  /* 功能色渐变终止色（PRE-3 新增） */
  --feeding-gradient-end: #98C498;
  --sleep-gradient-end: #9D8AB8;
  --diaper-gradient-end: #C4B898;
  --temperature-gradient-end: #C49898;
  --growth-gradient-end: #5B8FAF;
  --success-gradient-end: #8CB88C;

  /* FAB 和筛选色（PRE-3 新增） */
  --fab-start: #D4A574;
  --fab-end: #A67C52;
  --filter-active-start: #D4A574;
  --filter-active-end: #B88655;
  --filter-text: #6B6056;
  --batch-header-bg: #FFF5EB;
  --batch-header-border: #E8A87C;
  --active-bg-end: #EDE8E0;

  /* 首页快捷入口渐变终止色（PRE-3 新增） */
  --feeding-btn-end: #8BC48B;
  --sleep-btn-end: #9B8BC4;
  --sleep-timing-start: #A090C0;
  --sleep-timing-end: #8B7BB4;
  --sleep-abnormal-start: #D4A8A8;
  --sleep-abnormal-end: #C48B8B;
  --diaper-btn-end: #C4B48B;
  --temperature-btn-end: #C48B8B;
  --growth-btn-start: #7BA9C9;
  --growth-btn-end: #5B8FAF;

  /* ============ v4.0 新增变量（6 个） ============ */
  --growth-color: #7BA9C9;                                     /* 生长独立色 */
  --surface-elevated: rgba(212, 184, 150, 0.06);               /* 表面层次色 */
  --elevation-1: 0 2rpx 8rpx rgba(139, 123, 107, 0.04);       /* 层级阴影 L1 */
  --elevation-2: 0 4rpx 16rpx rgba(139, 123, 107, 0.06);      /* 层级阴影 L2 */
  --radius-pill: 999rpx;                                        /* 胶囊/标签圆角 */
  --radius-xl: 40rpx;                                           /* 弹窗大圆角 */

  background-color: var(--bg-primary);
  font-family: 'PingFang SC', 'Source Han Sans CN', sans-serif;
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-lg);
  font-size: 32rpx;
  padding: 0 var(--spacing-lg);
  margin: 20rpx 0;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--white);
  box-shadow: 0 4rpx 24rpx rgba(139, 123, 107, 0.2);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.15);
}

.btn-primary[disabled] {
  background: var(--disabled-start);
  color: var(--text-hint);
  box-shadow: none;
}

.btn-secondary {
  background: var(--bg-secondary);
  color: var(--primary-dark);
  border: 2rpx solid var(--primary-color);
}

.btn-secondary:active {
  transform: scale(0.98);
  background: var(--bg-primary);
}

.btn-text {
  background: transparent;
  color: var(--text-secondary);
  font-size: 28rpx;
  border: none;
  padding: 16rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--border-color);
  transition: all var(--transition-normal);
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.1);
}

.card.selected {
  border: 2rpx solid var(--primary-color);
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.1) 0%, 
    rgba(232, 220, 200, 0.2) 100%
  );
}

/* 渐变卡片 */
.card-gradient {
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.1) 0%, 
    rgba(232, 220, 200, 0.2) 100%
  );
}

/* 小精灵共同样式 */
.pet-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.pet-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  margin-bottom: 20rpx;
}

/* 状态条样式 */
.status-bar {
  width: 100%;
  height: 24rpx;
  background-color: var(--background-light);
  border-radius: 12rpx;
  overflow: hidden;
  margin: 10rpx 0;
}

.status-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.3s ease-out;
}

/* 功能色状态条 - 美拉德色系 */
.feeding-fill {
  background: linear-gradient(90deg, var(--feeding-color) 0%, #A8C4A8 100%);
}

.sleep-fill {
  background: linear-gradient(90deg, var(--sleep-color) 0%, #A898C4 100%);
}

.diaper-fill {
  background: linear-gradient(90deg, var(--diaper-color) 0%, #C4B898 100%);
}

.temperature-fill {
  background: linear-gradient(90deg, var(--temperature-color) 0%, #C49898 100%);
}

/* 旧版兼容 - 逐步废弃 */
.hunger-fill {
  background: linear-gradient(90deg, var(--feeding-color) 0%, #A8C4A8 100%);
}

.mood-fill {
  background: linear-gradient(90deg, var(--sleep-color) 0%, #A898C4 100%);
}

.energy-fill {
  background: linear-gradient(90deg, var(--diaper-color) 0%, #C4B898 100%);
}

.exp-fill {
  background: linear-gradient(90deg, var(--temperature-color) 0%, #C49898 100%);
}

/* flex 布局辅助类 */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.align-center {
  align-items: center;
}

.text-center {
  text-align: center;
}

/* 文本样式 - 字体层次系统 */
.title-hero {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.title-large {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.title-medium {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.title-small {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.5;
}

.body-large {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.6;
}

.body-medium {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.6;
}

.body-small {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-secondary);
  line-height: 1.5;
}

.caption {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--text-hint);
  line-height: 1.4;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--text-primary);
  text-align: left;
}

.subtitle {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: var(--text-secondary);
}

.text-sm {
  font-size: 24rpx;
  color: var(--text-hint);
}

.text-primary {
  color: var(--primary-color);
}

/* 徽章样式 */
.badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.badge-primary {
  background: linear-gradient(135deg, rgba(212, 165, 116, 0.15) 0%, rgba(196, 149, 106, 0.15) 100%);
  color: var(--primary-dark);
  border: 1rpx solid rgba(212, 165, 116, 0.3);
}

/* 分割线 */
.divider {
  width: 100%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-color) 50%, transparent 100%);
  margin: 24rpx 0;
}

/* 页面进入动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.page-enter {
  animation: fadeInUp 0.6s ease-out;
}

/* 卡片交错动画 */
.card-stagger:nth-child(1) { animation-delay: 0s; }
.card-stagger:nth-child(2) { animation-delay: 0.1s; }
.card-stagger:nth-child(3) { animation-delay: 0.2s; }
.card-stagger:nth-child(4) { animation-delay: 0.3s; }
.card-stagger:nth-child(5) { animation-delay: 0.4s; }

/* 按钮点击反馈 */
@keyframes buttonPress {
  0% { transform: scale(1); }
  50% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

/* 弹窗动画 */
@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideDown {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(100%);
    opacity: 0;
  }
}

.popup-enter {
  animation: slideUp 0.3s ease-out;
}

.popup-leave {
  animation: slideDown 0.3s ease-in;
}

/* 渐变动画 */
@keyframes gradientShift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

/* 脉冲动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

/* 加载动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.loading-spinner {
  animation: spin 1s linear infinite;
}

.card {
  animation: fadeInUp 0.6s ease-out;
}

/* ============ v4.0 新增动画（3 个） ============ */

/* 进度条增长动画 */
@keyframes progressGrow {
  from { width: 0; }
  to { width: var(--progress-target); }
}

/* 录制指示灯呼吸动画 */
@keyframes recPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* 胶囊状态切换过渡 */
@keyframes capsuleTransition {
  0% { opacity: 0.7; transform: scale(0.98); }
  100% { opacity: 1; transform: scale(1); }
}

/* 减少动画偏好 - 小程序不支持 * 通配符，使用 page/view 替代 */
@media (prefers-reduced-motion: reduce) {
  page, view, text, image, scroll-view {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* v4.0: 通用 picker 箭头 image */
.picker-arrow-img {
  width: 16rpx;
  height: 16rpx;
  opacity: 0.4;
}

/* ============================================================
 * 暖夜模式 CSS 变量覆盖
 * 仅在 class="dark-mode" 的元素及其子元素中生效
 * 亮色模式下此块完全不生效，零影响
 * ============================================================ */

.dark-mode {
  /* === 主色调 === */
  --primary-color: #D4B896;          /* 品牌色不变 */
  --primary-light: #3D3428;          /* 深棕（替代米白） */
  --primary-dark: #C4A890;           /* 提亮（暗底上需要更亮） */
  --accent-color: #8BAF8B;           /* 薄荷绿降饱和 */

  /* === 功能色（降饱和约15%） === */
  --feeding-color: #7CAF7C;
  --sleep-color: #9488B4;
  --diaper-color: #B0A480;
  --temperature-color: #B48888;

  /* === 语义功能色 === */
  --success-color: #6AB845;
  --danger-color: #D44848;
  --warning-color: #C47830;
  --info-color: #6B93B9;

  /* === 语义背景色 === */
  --warning-bg: #2E2518;
  --danger-bg: #2E1818;

  /* === 渐变色 === */
  --success-gradient: linear-gradient(135deg, #6AB845, #8CB86A);
  --danger-gradient: linear-gradient(135deg, #D44848, #E08888);

  /* === 文字色 === */
  --text-primary: #E8E0D8;
  --text-secondary: #B0A898;
  --text-hint: #7A7068;
  --text-tertiary: #7A7068;
  --text-color: #E8E0D8;

  /* === 背景色 === */
  --bg-primary: #1E1A16;
  --bg-secondary: #2A2420;
  --bg-card: #2A2420;
  --background-light: #1E1A16;
  --background: #1E1A16;

  /* === 阴影（暗底上改用黑色阴影） === */
  --shadow-card: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
  --shadow-soft: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  --shadow-popup: 0 8rpx 48rpx rgba(0, 0, 0, 0.5);

  /* === 遮罩色 === */
  --mask-color: rgba(0, 0, 0, 0.6);
  --mask-color-dark: rgba(0, 0, 0, 0.75);

  /* === 渐变终止色 === */
  --gradient-end: #A08860;
  --disabled-start: #3D3428;
  --disabled-end: #332C20;

  /* === 功能色渐变背景（暗色版） === */
  --feeding-bg: linear-gradient(135deg, #1A2A1A 0%, #1E2E1E 100%);
  --sleep-bg: linear-gradient(135deg, #1E1A2A 0%, #24203A 100%);
  --diaper-bg: linear-gradient(135deg, #2A2618 0%, #2E2A1C 100%);
  --temperature-bg: linear-gradient(135deg, #2A1A1A 0%, #2E1E1E 100%);

  /* === 其他 === */
  --white: #E8E0D8;
  --border-color: rgba(212, 184, 150, 0.08);

  /* === 语义扩展变量 === */
  --text-warm-brown: #C4A890;
  --accent-warm: #D4A574;
  --bg-hover: rgba(212, 184, 150, 0.12);
  --border-warm: rgba(196, 154, 108, 0.15);
  --percentile-normal-bg: rgba(106, 184, 69, 0.15);
  --percentile-normal-text: #7BC950;
  --percentile-abnormal-bg: rgba(212, 72, 72, 0.15);
  --percentile-abnormal-text: #E88080;

  /* === 页面背景色（确保容器背景也变暗） === */
  background-color: #1E1A16;
  color: #E8E0D8;

  /* === 功能色渐变终止色（暗色版） === */
  --feeding-gradient-end: #5C8F5C;
  --sleep-gradient-end: #7A6898;
  --diaper-gradient-end: #A09068;
  --temperature-gradient-end: #A07070;
  --growth-gradient-end: #4A7A94;
  --success-gradient-end: #6A986A;

  /* === FAB 和筛选色（暗色版） === */
  --fab-start: #B08858;
  --fab-end: #886438;
  --filter-active-start: #B08858;
  --filter-active-end: #986C3C;
  --filter-text: #B0A898;
  --batch-header-bg: #2E2518;
  --batch-header-border: #A07850;
  --active-bg-end: #2A2420;

  /* === 首页快捷入口渐变终止色（暗色版） === */
  --feeding-btn-end: #5C8F5C;
  --sleep-btn-end: #7A6898;
  --sleep-timing-start: #7A6898;
  --sleep-timing-end: #6A5888;
  --sleep-abnormal-start: #B48888;
  --sleep-abnormal-end: #A07070;
  --diaper-btn-end: #A09068;
  --temperature-btn-end: #A07070;
  --growth-btn-start: #5A8CA8;
  --growth-btn-end: #4A7A94;

  /* === 密度块色（暗色版） === */
  --density-level-0: #3D3428;
  --density-level-2: #A08050;
  --density-level-3: #886840;
  --density-level-4: #705838;

  /* === v4.0 新增变量暗色覆盖（4 个） === */
  --growth-color: #5C8CA8;
  --surface-elevated: rgba(212, 184, 150, 0.04);
  --elevation-1: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  --elevation-2: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  /* --radius-pill / --radius-xl 为固定值，无需暗色覆盖 */
}

/* ============================================================
 * 主题过渡动画支持
 * 仅在切换主题时临时添加，300ms 后移除
 * ============================================================ */

.theme-transition,
.theme-transition view,
.theme-transition text,
.theme-transition image {
  transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

/* ============================================================
 * switch 组件暗色覆盖
 * ============================================================ */

.dark-mode switch .wx-switch-input {
  background: #3D3428 !important;
  border-color: rgba(212, 184, 150, 0.2) !important;
}

.dark-mode switch .wx-switch-input.wx-switch-input-checked {
  background: #D4B896 !important;
  border-color: #D4B896 !important;
}

/* ============================================================
 * 图标暗色适配
 * 灰色线条图标在深色背景上提亮
 * ============================================================ */

.dark-mode .icon-gray,
.dark-mode .menu-arrow,
.dark-mode .back-icon {
  filter: brightness(1.5);
}

.dark-mode .header-icon image {
  filter: brightness(1.2);
}