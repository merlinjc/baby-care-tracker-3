/* 编辑宝宝信息弹窗样式 - 美拉德色彩风格 */

/* 弹窗遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(90, 74, 58, 0.6);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.popup-mask-visible {
  opacity: 1;
  visibility: visible;
}

/* 弹窗容器 */
.popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-secondary);
  border-radius: 40rpx 40rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.popup-enter {
  transform: translateY(0);
}

/* 下滑指示条 */
.swipe-indicator {
  width: 64rpx;
  height: 8rpx;
  background: var(--border-color);
  border-radius: 4rpx;
  margin: 16rpx auto 0;
  flex-shrink: 0;
}

/* 标题栏 */
.popup-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid var(--border-color);
  flex-shrink: 0;
}

.popup-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.popup-icon image {
  width: 28rpx;
  height: 28rpx;
}

.popup-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.popup-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-hint);
  line-height: 1;
}

/* 内容区域 */
.popup-content {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* v4.0: 头像 100rpx */
.avatar-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  box-shadow: 0 4rpx 16rpx rgba(212, 184, 150, 0.4);
}

.avatar-edit-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to top, rgba(90, 74, 58, 0.8) 0%, transparent 100%);
  border-radius: 0 0 80rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 16rpx;
}

.camera-icon {
  width: 32rpx;
  height: 32rpx;
  margin-bottom: 4rpx;
}

.avatar-edit-text {
  font-size: 20rpx;
  color: var(--white);
}

.avatar-uploading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 表单区域 */
.form-section {
  background: var(--bg-primary);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-label image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.7;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  background: var(--bg-secondary);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--primary-color);
  background: var(--bg-primary);
}

.input-placeholder {
  color: var(--text-hint);
}

/* 日期选择器 */
.date-picker {
  height: 88rpx;
  display: flex;
  align-items: center;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.date-picker:focus {
  border-color: var(--primary-color);
  background: var(--bg-primary);
}

.date-picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 100%;
  padding: 0 24rpx;
}

.date-value {
  font-size: 32rpx;
  color: var(--text-primary);
}

.date-placeholder {
  font-size: 32rpx;
  color: var(--text-hint);
}

.date-picker-content image {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--white);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(212, 184, 150, 0.4);
  transition: all 0.3s ease;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(212, 184, 150, 0.3);
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, var(--disabled-start) 0%, var(--disabled-end) 100%);
  box-shadow: none;
  opacity: 0.6;
}

.submit-btn.loading {
  opacity: 0.7;
}
