<!--排便记录弹窗-->
<view class="{{darkMode ? 'dark-mode' : ''}} popup-mask popup-mask-visible" 
      hidden="{{!show}}"
      bindtap="close"
      catchtouchmove="preventMove">
  <view class="popup-container popup-enter" 
        style="transform: translateY({{popupTranslateY}}px)"
        catchtap="stopPropagation"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd">
    <!-- 下滑指示条 -->
    <view class="swipe-indicator"></view>
    <!-- 标题栏 -->
    <view class="popup-header">
      <view class="popup-icon">
        <image src="/images/icons/diaper-color.png" 
               mode="aspectFit" lazy-load></image>
      </view>
      <text class="popup-title">排便记录</text>
      <view class="popup-close" bindtap="close">
        <image src="/images/icons/x-mark.png" mode="aspectFit" />
      </view>
    </view>

    <!-- 可滚动内容区域 -->
    <scroll-view class="popup-content" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="popup-inner">
      <!-- 排便类型 -->
      <view class="section">
        <text class="section-title">排便类型</text>
        <view class="types">
          <view 
            wx:for="{{types}}" 
            wx:key="value"
            class="type-item {{diaperType === item.value ? 'active' : ''}}"
            data-type="{{item.value}}"
            bindtap="selectType"
          >
            <view class="type-icon">
              <image src="{{item.iconUrl}}" mode="aspectFit" lazy-load></image>
            </view>
            <text class="type-label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 大便质地（仅大便和混合） -->
      <view class="section" wx:if="{{diaperType !== 'pee' && diaperType !== ''}}">
        <text class="section-title">大便质地</text>
        <view class="consistencies">
          <view 
            wx:for="{{consistencies}}" 
            wx:key="value"
            class="consistency-item {{consistency === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectConsistency"
          >
            <text class="consistency-label">{{item.label}}</text>
            <text class="consistency-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 大便颜色（仅大便和混合） -->
      <view class="section" wx:if="{{diaperType !== 'pee' && diaperType !== ''}}">
        <text class="section-title">大便颜色</text>
        <view class="colors">
          <view 
            wx:for="{{colors}}" 
            wx:key="value"
            class="color-item {{color === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectColor"
          >
            <view class="color-circle" style="background: {{item.color}};"></view>
            <text class="color-label">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 预警信息 -->
      <view class="warning-banner {{warning.type}}" wx:if="{{warning}}">
        <view class="warning-icon"></view>
        <text class="warning-message">{{warning.message}}</text>
      </view>

      <!-- 提交按钮 -->
      <button 
        class="submit-btn {{loading ? 'loading disabled' : ''}}"
        bindtap="submit"
        disabled="{{loading}}"
      >
        <text wx:if="{{!loading}}">保存记录</text>
        <text wx:else>保存中...</text>
      </button>
      </view>
    </scroll-view>
  </view>
</view>
