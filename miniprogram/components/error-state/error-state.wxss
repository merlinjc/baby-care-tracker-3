/* 错误状态组件样式 - 美拉德色彩 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  min-height: 400rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.icon-img {
  width: 80rpx;
  height: 80rpx;
}

.error-message {
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
  max-width: 80%;
}

.retry-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, var(--primary-color, #D4B896) 0%, var(--primary-dark, #8B7B6B) 100%);
  color: var(--white);
  font-size: 28rpx;
  border-radius: 48rpx;
  border: none;
  transition: all 0.2s ease;
}

.retry-btn:active {
  transform: scale(0.98);
}

.retry-btn.loading {
  opacity: 0.7;
}
