/* 喂养记录弹窗样式 - 美拉德色彩风格 */
@import '../../styles/popup.wxss';

/* 喂养主题色覆盖 */
.popup-icon {
  background: linear-gradient(135deg, 
    rgba(168, 212, 168, 0.15) 0%, 
    rgba(168, 194, 168, 0.2) 100%
  );
}

/* 喂养类型 */
.feeding-types {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.feeding-type-item {
  flex: 1;
  padding: var(--spacing-md) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.feeding-type-item.active {
  background: linear-gradient(135deg, 
    rgba(168, 212, 168, 0.15) 0%, 
    rgba(168, 194, 168, 0.2) 100%
  );
  border-color: var(--feeding-color);
}

.feeding-type-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feeding-type-icon image {
  width: 48rpx;
  height: 48rpx;
}

.feeding-type-label {
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 分段 */
.section {
  margin-bottom: var(--spacing-lg);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

/* 母乳侧 — v4.0: pill 胶囊按钮 */
.breast-sides {
  display: flex;
  gap: var(--spacing-sm);
}

.breast-side-item {
  flex: 1;
  padding: var(--spacing-md) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-pill);
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.breast-side-item.active {
  background: rgba(168, 212, 168, 0.15);
  color: var(--feeding-color);
  font-weight: 500;
}

/* 喂养量输入 */
.amount-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: 28rpx;
  color: var(--text-primary);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
  box-sizing: border-box;
}

.amount-input:focus {
  border-color: var(--feeding-color);
  background: var(--bg-secondary);
}

/* 计时器 */
.timer-section {
  margin-bottom: var(--spacing-lg);
}

/* 快捷时长选择 */
.quick-duration {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.quick-duration-item {
  flex: 1;
  min-width: calc(20% - var(--spacing-sm));
  padding: var(--spacing-sm) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.quick-duration-item.active {
  background: linear-gradient(135deg,
    rgba(168, 212, 168, 0.15) 0%,
    rgba(168, 194, 168, 0.2) 100%
  );
  color: var(--feeding-color);
  font-weight: 500;
  border-color: var(--feeding-color);
}

.quick-duration-item:active {
  transform: scale(0.95);
}

/* v4.0: 常用量快捷填入 */
.recent-amounts {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: var(--spacing-md);
  padding: 12rpx 16rpx;
  background: rgba(168, 212, 168, 0.06);
  border-radius: var(--radius-md);
}

.recent-label {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.recent-item {
  padding: 6rpx 16rpx;
  background: rgba(168, 212, 168, 0.12);
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--feeding-color);
  font-weight: 500;
}

.recent-item:active {
  background: rgba(168, 212, 168, 0.25);
}

/* 快捷用量选择 - 配方奶 */
.quick-amount {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.quick-amount-item {
  flex: 1;
  min-width: calc(25% - var(--spacing-sm));
  padding: var(--spacing-sm) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.quick-amount-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg,
    rgba(168, 212, 168, 0.15) 0%,
    rgba(168, 194, 168, 0.2) 100%
  );
  color: var(--feeding-color);
  font-weight: 500;
}

/* 奶量显示 */
.amount-display {
  text-align: center;
  padding: var(--spacing-lg) 0;
  background: linear-gradient(135deg,
    rgba(168, 212, 168, 0.15) 0%,
    rgba(168, 194, 168, 0.1) 100%
  );
  border-radius: var(--radius-md);
  position: relative;
}

.amount-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.amount-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--feeding-color);
}

.amount-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx 20rpx;
  background: rgba(139, 123, 107, 0.1);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.amount-clear:active {
  background: rgba(139, 123, 107, 0.2);
  color: var(--text-primary);
}

/* 分隔线 */
.timer-divider {
  text-align: center;
  margin: var(--spacing-md) 0;
}

.timer-divider text {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 0 var(--spacing-md);
  background: var(--bg-secondary);
  position: relative;
}

.timer-divider::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 1rpx;
  background: var(--border-color);
}

.timer-display {
  text-align: center;
  padding: var(--spacing-lg) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
}

.timer-text {
  font-size: 48rpx;
  font-weight: 600;
  color: var(--feeding-color);
  font-variant-numeric: tabular-nums;
}

.timer-controls {
  display: flex;
  gap: var(--spacing-sm);
}

.timer-btn {
  flex: 1;
  padding: var(--spacing-md) 0;
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.timer-btn.start {
  background: linear-gradient(135deg, var(--feeding-color) 0%, #98C498 100%);
  color: var(--white);
  box-shadow: 0 4rpx 16rpx rgba(168, 212, 168, 0.3);
}

.timer-btn.start:active {
  transform: scale(0.98);
}

.timer-btn.pause {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--white);
  box-shadow: 0 4rpx 16rpx rgba(139, 123, 107, 0.2);
}

.timer-btn.pause:active {
  transform: scale(0.98);
}

.timer-btn.stop {
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.timer-btn.stop:active {
  background: var(--bg-secondary);
}

/* 提交按钮 - 喂养主题色 */
.submit-btn {
  background: linear-gradient(135deg, var(--feeding-color) 0%, var(--feeding-gradient-end, #98C498) 100%);
  box-shadow: 0 4rpx 24rpx rgba(168, 212, 168, 0.3);
}
.duration-display {
  text-align: center;
  padding: var(--spacing-lg) 0;
  background: linear-gradient(135deg, 
    rgba(168, 212, 168, 0.15) 0%, 
    rgba(168, 194, 168, 0.1) 100%
  );
  border-radius: var(--radius-md);
  margin-top: var(--spacing-md);
  position: relative;
}

.duration-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.duration-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--feeding-color);
}

.duration-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx 20rpx;
  background: rgba(139, 123, 107, 0.1);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.duration-clear:active {
  background: rgba(139, 123, 107, 0.2);
  color: var(--text-primary);
}


