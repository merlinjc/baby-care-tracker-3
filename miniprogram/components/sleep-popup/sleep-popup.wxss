/* 睡眠记录弹窗样式 */
@import '../../styles/popup.wxss';

/* 睡眠主题色覆盖 */
.popup-icon {
  background: linear-gradient(135deg, 
    rgba(184, 168, 212, 0.15) 0%, 
    rgba(168, 152, 196, 0.2) 100%
  );
}

/* 睡眠弹窗尺寸覆盖 */
.popup-container {
  max-height: 85vh;
}

.popup-content {
  height: calc(85vh - 180rpx);
}

/* v4.0: 模式切换 pill */
.mode-tabs {
  display: flex;
  background: var(--bg-primary);
  border-radius: var(--radius-pill);
  padding: 6rpx;
  margin-bottom: var(--spacing-lg);
}

.mode-tab {
  flex: 1;
  padding: var(--spacing-sm) 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-pill);
  transition: all var(--transition-fast);
}

.mode-tab.active {
  background: var(--bg-secondary);
  color: var(--sleep-color);
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 分段 */
.section {
  margin-bottom: var(--spacing-lg);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.section-toggle {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 睡眠类型 */
.sleep-types {
  display: flex;
  gap: var(--spacing-sm);
}

.sleep-type-item {
  flex: 1;
  padding: var(--spacing-md) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.sleep-type-item.active {
  background: linear-gradient(135deg, 
    rgba(184, 168, 212, 0.15) 0%, 
    rgba(168, 152, 196, 0.2) 100%
  );
  border-color: var(--sleep-color);
}

.sleep-type-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sleep-type-icon image {
  width: 48rpx;
  height: 48rpx;
}

.sleep-type-label {
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 快捷时长选择 */
.quick-duration {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.quick-duration-item {
  flex: 1;
  min-width: calc(20% - var(--spacing-sm));
  padding: var(--spacing-sm) 0;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.quick-duration-item.active {
  background: linear-gradient(135deg, 
    rgba(184, 168, 212, 0.15) 0%, 
    rgba(168, 152, 196, 0.2) 100%
  );
  color: var(--sleep-color);
  font-weight: 500;
  border-color: var(--sleep-color);
}

.quick-duration-item:active {
  transform: scale(0.95);
}

/* 时间选择器 */
.time-picker-group {
  display: flex;
  gap: var(--spacing-sm);
}

.time-picker-item {
  flex: 1;
}

.time-picker-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.time-picker-value {
  height: 80rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
}

/* 时长显示 */
.duration-display {
  text-align: center;
  padding: var(--spacing-lg) 0;
  background: linear-gradient(135deg, 
    rgba(184, 168, 212, 0.15) 0%, 
    rgba(168, 152, 196, 0.1) 100%
  );
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-lg);
  position: relative;
}

.duration-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.duration-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--sleep-color);
}

.duration-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx 20rpx;
  background: rgba(139, 123, 107, 0.1);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
}

.duration-clear:active {
  background: rgba(139, 123, 107, 0.2);
  color: var(--text-primary);
}

/* 睡眠地点 */
.location-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

/* v4.0: 地点选择 pill */
.location-item {
  padding: 16rpx 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.location-item.active {
  background: linear-gradient(135deg, 
    rgba(184, 168, 212, 0.15) 0%, 
    rgba(168, 152, 196, 0.2) 100%
  );
  color: var(--sleep-color);
  font-weight: 500;
  border-color: var(--sleep-color);
}

/* 提交按钮 - 睡眠主题色 */
.submit-btn {
  background: linear-gradient(135deg, var(--sleep-color) 0%, #9D8AB8 100%);
  box-shadow: 0 4rpx 24rpx rgba(184, 168, 212, 0.3);
}

/* 追踪模式 */
.tracking-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

.tracking-status {
  margin-bottom: var(--spacing-md);
}

.tracking-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.tracking-time {
  margin-bottom: var(--spacing-xl);
}

.tracking-time-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--sleep-color);
  font-variant-numeric: tabular-nums;
}

.tracking-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
}

.tracking-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-lg);
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.tracking-btn.start {
  background: linear-gradient(135deg, var(--sleep-color) 0%, var(--sleep-gradient-end, #9D8AB8) 100%);
  color: var(--white);
  box-shadow: 0 4rpx 24rpx rgba(184, 168, 212, 0.3);
}

.tracking-btn.finish {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--white);
  box-shadow: 0 4rpx 24rpx rgba(212, 184, 150, 0.3);
}

.tracking-btn.cancel {
  background: transparent;
  color: var(--text-secondary);
}

.tracking-btn:active {
  transform: scale(0.98);
}
