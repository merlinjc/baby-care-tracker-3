/* 宝宝详情页面样式 - 美拉德色彩风格 */

.baby-detail-container {
  padding: var(--spacing-lg);
  background: var(--bg-secondary);
  min-height: 100vh;
}

/* 头部区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xxl) 0;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: var(--spacing-md);
}

.baby-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid var(--bg-primary);
  box-shadow: 0 8rpx 32rpx rgba(139, 123, 107, 0.2);
}

/* 头像编辑提示 */
.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--gradient-end) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(212, 184, 150, 0.4);
  transition: all var(--transition-fast);
}

.avatar-edit-hint image {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

/* 上传中状态 */
.avatar-uploading {
  position: absolute;
  top: 0;
  left: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: var(--white);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--gradient-end) 100%);
  border-radius: 50%;
  border: 4rpx solid var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(212, 184, 150, 0.4);
}

.avatar-badge image {
  width: 32rpx;
  height: 32rpx;
}

.baby-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.baby-age {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 信息卡片 */
.info-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-soft);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--border-color);
}

.info-item:last-child {
  border-bottom: none;
}

.info-left {
  display: flex;
  align-items: center;
}

.info-left image {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--spacing-sm);
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  margin-left: -16rpx;
  margin-right: -16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  font-size: 32rpx;
  color: var(--text-primary);
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-color);
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-soft);
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.8;
}

.action-btn image {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--spacing-sm);
}

.action-btn.primary {
  color: var(--white);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--gradient-end) 100%);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(212, 184, 150, 0.4);
}

.action-btn.primary image {
  width: 32rpx;
  height: 32rpx;
}
