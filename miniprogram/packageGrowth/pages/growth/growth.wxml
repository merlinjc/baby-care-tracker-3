<!--生长发育追踪页-->
<view class="page-container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 数据类型选择 -->
  <view class="type-selector">
    <scroll-view scroll-x enhanced show-scrollbar="{{false}}">
      <view class="type-tabs">
        <view 
          class="type-tab {{dataType === 'weight' ? 'active' : ''}}" 
          bindtap="onDataTypeChange" 
          data-type="weight"
        >
          <image class="tab-icon" src="/images/icons/weight.png" mode="aspectFit"></image>
          <text class="tab-text">体重</text>
        </view>
        <view 
          class="type-tab {{dataType === 'height' ? 'active' : ''}}" 
          bindtap="onDataTypeChange" 
          data-type="height"
        >
          <image class="tab-icon" src="/images/icons/height.png" mode="aspectFit"></image>
          <text class="tab-text">身高</text>
        </view>
        <view 
          class="type-tab {{dataType === 'head' ? 'active' : ''}}" 
          bindtap="onDataTypeChange" 
          data-type="head"
        >
          <image class="tab-icon" src="/images/icons/head.png" mode="aspectFit"></image>
          <text class="tab-text">头围</text>
        </view>
        <view 
          class="type-tab {{dataType === 'bmi' ? 'active' : ''}}" 
          bindtap="onDataTypeChange" 
          data-type="bmi"
        >
          <image class="tab-icon" src="/images/icons/bmi.png" mode="aspectFit"></image>
          <text class="tab-text">BMI</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 生长曲线图 -->
    <view class="chart-section">
      <view class="section-header">
        <view class="header-left">
          <text class="section-title">生长曲线</text>
          <text class="section-subtitle">WHO标准对照</text>
        </view>
        <view class="header-right" bindtap="showWhoDetail">
          <image class="info-icon" src="/images/icons/info.png" mode="aspectFit"></image>
        </view>
      </view>
      
      <view class="chart-container">
        <canvas 
          type="2d" 
          id="growthChart" 
          class="growth-canvas"
          canvas-id="growthChart"
        ></canvas>
      </view>
      
      <view class="chart-legend">
        <view class="legend-row">
          <view class="legend-item">
            <view class="legend-dot baby"></view>
            <text>宝宝数据</text>
          </view>
          <view class="legend-item">
            <view class="legend-line p50"></view>
            <text>P50 中位线</text>
          </view>
          <view class="legend-item">
            <view class="legend-line p15"></view>
            <text>P15/P85</text>
          </view>
          <view class="legend-item">
            <view class="legend-line p3"></view>
            <text>P3/P97</text>
          </view>
        </view>
        <view class="legend-row bands">
          <view class="legend-item">
            <view class="legend-band green"></view>
            <text>正常</text>
          </view>
          <view class="legend-item">
            <view class="legend-band yellow"></view>
            <text>关注</text>
          </view>
          <view class="legend-item">
            <view class="legend-band red"></view>
            <text>偏离</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 最新数据卡片 -->
    <view class="data-section" wx:if="{{latestData}}">
      <view class="section-header">
        <text class="section-title">最新数据</text>
        <text class="section-date">{{latestData.dateText}}</text>
      </view>
      
      <view class="data-cards">
        <!-- 体重卡片 -->
        <view class="data-card weight" wx:if="{{latestData.data.weight}}">
          <view class="card-header">
            <text class="card-label">体重</text>
            <view class="card-percentile {{latestData.percentile.weightLevel}}">
              <text>P{{latestData.percentile.weightP}}</text>
            </view>
          </view>
          <view class="card-value">
            <text class="value-num">{{latestData.data.weight}}</text>
            <text class="value-unit">kg</text>
          </view>
          <view class="card-tip">{{latestData.percentile.weightTip}}</view>
          <view class="card-reference" wx:if="{{whoReference.weight}}">
            <text class="ref-label">WHO参考: P3 {{whoReference.weight.p3}} ~ P97 {{whoReference.weight.p97}}</text>
          </view>
        </view>
        
        <!-- 身高卡片 -->
        <view class="data-card height" wx:if="{{latestData.data.height}}">
          <view class="card-header">
            <text class="card-label">身高</text>
            <view class="card-percentile {{latestData.percentile.heightLevel}}">
              <text>P{{latestData.percentile.heightP}}</text>
            </view>
          </view>
          <view class="card-value">
            <text class="value-num">{{latestData.data.height}}</text>
            <text class="value-unit">cm</text>
          </view>
          <view class="card-tip">{{latestData.percentile.heightTip}}</view>
          <view class="card-reference" wx:if="{{whoReference.height}}">
            <text class="ref-label">WHO参考: P3 {{whoReference.height.p3}} ~ P97 {{whoReference.height.p97}}</text>
          </view>
        </view>
        
        <!-- 头围卡片 -->
        <view class="data-card head" wx:if="{{latestData.data.headCircumference}}">
          <view class="card-header">
            <text class="card-label">头围</text>
            <view class="card-percentile {{latestData.percentile.headLevel}}">
              <text>P{{latestData.percentile.headP}}</text>
            </view>
          </view>
          <view class="card-value">
            <text class="value-num">{{latestData.data.headCircumference}}</text>
            <text class="value-unit">cm</text>
          </view>
          <view class="card-tip">{{latestData.percentile.headTip}}</view>
          <view class="card-reference" wx:if="{{whoReference.head}}">
            <text class="ref-label">WHO参考: P3 {{whoReference.head.p3}} ~ P97 {{whoReference.head.p97}}</text>
          </view>
        </view>
        
        <!-- BMI卡片 -->
        <view class="data-card bmi" wx:if="{{latestData.bmi}}">
          <view class="card-header">
            <text class="card-label">BMI</text>
            <view class="card-percentile {{latestData.bmiLevel}}">
              <text>{{latestData.bmiStatus}}</text>
            </view>
          </view>
          <view class="card-value">
            <text class="value-num">{{latestData.bmi}}</text>
            <text class="value-unit">kg/m²</text>
          </view>
          <view class="card-tip">{{latestData.bmiTip}}</view>
          <view class="card-reference" wx:if="{{whoReference.bmi}}">
            <text class="ref-label">WHO参考: P3 {{whoReference.bmi.p3}} ~ P97 {{whoReference.bmi.p97}}</text>
          </view>
        </view>
      </view>
      
      <!-- 发育评估 -->
      <view class="evaluation-card {{evaluation.level}}">
        <view class="evaluation-icon">
          <icon type="{{evaluation.iconType}}" name="{{evaluation.iconName}}" size="small" />
        </view>
        <view class="evaluation-content">
          <text class="evaluation-title">发育评估</text>
          <text class="evaluation-text">{{evaluation.text}}</text>
        </view>
      </view>
    </view>

    <!-- 无数据提示 -->
    <view class="empty-section" wx:else>
      <image class="empty-icon" src="/images/icons/growth-color.png" mode="aspectFit" lazy-load></image>
      <text class="empty-title">暂无生长记录</text>
      <text class="empty-desc">点击右下角按钮添加宝宝的生长数据</text>
    </view>

    <!-- 历史记录 -->
    <view class="history-section" wx:if="{{growthRecords.length > 0}}">
      <view class="section-header">
        <text class="section-title">历史记录</text>
        <text class="section-count">共{{growthRecords.length}}条</text>
      </view>
      
      <view class="history-list">
        <view 
          class="history-item" 
          wx:for="{{growthRecords}}" 
          wx:key="_id"
          bindtap="showRecordDetail"
          data-index="{{index}}"
        >
          <view class="item-date">{{item.dateText}}</view>
          <view class="item-data">
            <text class="data-tag weight" wx:if="{{item.data.weight}}">{{item.data.weight}}kg</text>
            <text class="data-tag height" wx:if="{{item.data.height}}">{{item.data.height}}cm</text>
            <text class="data-tag head" wx:if="{{item.data.headCircumference}}">{{item.data.headCircumference}}cm</text>
          </view>
          <view class="item-arrow">
            <image class="picker-arrow-img" src="/images/icons/arrow-right.png" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 浮动添加按钮 -->
  <view class="float-add-btn" bindtap="showAddPopup">
    <image class="add-btn-icon" src="/images/icons/add-white.png" mode="aspectFit"></image>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view class="popup-mask" wx:if="{{showAddPopup}}" bindtap="hideAddPopup">
    <view class="add-popup" 
          style="transform: translateY({{popupTranslateY}}px)"
          catchtap
          bindtouchstart="onPopupTouchStart"
          bindtouchmove="onPopupTouchMove"
          bindtouchend="onPopupTouchEnd">
      <!-- 下滑指示条 -->
      <view class="swipe-indicator"></view>
      <view class="popup-header">
        <text class="popup-title">{{editingRecord ? '编辑数据' : '添加生长数据'}}</text>
        <view class="popup-close" bindtap="hideAddPopup">
          <text>×</text>
        </view>
      </view>
      
      <scroll-view class="popup-content" scroll-y>
        <view class="popup-inner">
          <view class="form-section">
            <view class="form-label">测量日期</view>
            <picker mode="date" value="{{formData.date}}" bindchange="onDateChange">
              <view class="form-picker">
                <text class="picker-value">{{formData.date || '请选择日期'}}</text>
                <image class="picker-arrow-img" src="/images/icons/arrow-right.png" mode="aspectFit" />
              </view>
            </picker>
          </view>
          
          <view class="form-section">
            <view class="form-label">
              <text>体重</text>
              <text class="label-unit">(kg)</text>
            </view>
            <input 
              class="form-input" 
              type="digit" 
              placeholder="请输入体重"
              value="{{formData.weight}}"
              bindinput="onWeightInput"
            />
            <text class="form-hint">{{weightRange}}</text>
          </view>
          
          <view class="form-section">
            <view class="form-label">
              <text>身高</text>
              <text class="label-unit">(cm)</text>
            </view>
            <input 
              class="form-input" 
              type="digit" 
              placeholder="请输入身高"
              value="{{formData.height}}"
              bindinput="onHeightInput"
            />
            <text class="form-hint">{{heightRange}}</text>
          </view>
          
          <view class="form-section">
            <view class="form-label">
              <text>头围</text>
              <text class="label-unit">(cm)</text>
              <text class="label-optional">可选</text>
            </view>
            <input 
              class="form-input" 
              type="digit" 
              placeholder="请输入头围"
              value="{{formData.headCircumference}}"
              bindinput="onHeadInput"
            />
            <text class="form-hint">{{headRange}}</text>
          </view>
          
          <view class="form-section">
            <view class="form-label">
              <text>备注</text>
              <text class="label-optional">可选</text>
            </view>
            <textarea 
              class="form-textarea" 
              placeholder="添加备注信息"
              value="{{formData.note}}"
              bindinput="onNoteInput"
            ></textarea>
          </view>
        </view>
      </scroll-view>
      
      <view class="popup-footer">
        <view class="btn-cancel" bindtap="hideAddPopup">取消</view>
        <view class="btn-save" bindtap="saveGrowthData">保存</view>
      </view>
    </view>
  </view>

  <!-- WHO标准详情弹窗 -->
  <view class="popup-mask" wx:if="{{showWhoPopup}}" bindtap="hideWhoPopup">
    <view class="who-popup" catchtap>
      <view class="popup-header">
        <text class="popup-title">WHO儿童生长标准</text>
        <view class="popup-close" bindtap="hideWhoPopup">
          <text>×</text>
        </view>
      </view>
      
      <scroll-view class="popup-content" scroll-y>
        <view class="who-section">
          <text class="who-label">数据来源</text>
          <text class="who-text">世界卫生组织（WHO）2006年发布的儿童生长标准，基于多中心生长参考研究（MGRS）。</text>
        </view>
        
        <view class="who-section">
          <text class="who-label">百分位说明</text>
          <view class="percentile-list">
            <view class="percentile-item low">
              <text class="percentile-name">P3以下</text>
              <text class="percentile-desc">偏低，需关注</text>
            </view>
            <view class="percentile-item below-normal">
              <text class="percentile-name">P3-P15</text>
              <text class="percentile-desc">偏低正常</text>
            </view>
            <view class="percentile-item normal">
              <text class="percentile-name">P15-P85</text>
              <text class="percentile-desc">正常范围</text>
            </view>
            <view class="percentile-item below-normal">
              <text class="percentile-name">P85-P97</text>
              <text class="percentile-desc">偏高正常</text>
            </view>
            <view class="percentile-item high">
              <text class="percentile-name">P97以上</text>
              <text class="percentile-desc">偏高，需关注</text>
            </view>
          </view>
        </view>
        
        <view class="who-section">
          <text class="who-label">图表颜色区域说明</text>
          <view class="color-guide-box">
            <view class="color-guide-item">
              <view class="color-swatch green"></view>
              <view class="color-guide-text">
                <text class="guide-title">绿色区域（P15-P85）</text>
                <text class="guide-desc">正常范围，生长发育良好</text>
              </view>
            </view>
            <view class="color-guide-item">
              <view class="color-swatch yellow"></view>
              <view class="color-guide-text">
                <text class="guide-title">黄色区域（P3-P15 / P85-P97）</text>
                <text class="guide-desc">关注区域，仍属正常范围，可持续观察</text>
              </view>
            </view>
            <view class="color-guide-item">
              <view class="color-swatch red"></view>
              <view class="color-guide-text">
                <text class="guide-title">红色区域（&lt;P3 / &gt;P97）</text>
                <text class="guide-desc">偏离区域，建议及时咨询医生</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="who-section">
          <text class="who-label">BMI 说明</text>
          <view class="bmi-info-box">
            <text class="who-text">BMI（体重指数）= 体重(kg) ÷ 身高(m)²，是评估婴幼儿体型比例的重要指标。</text>
            <view class="bmi-tips">
              <text class="tips-item">• 婴儿 BMI 在出生后前几个月会快速上升，约4-6月龄达到峰值后逐渐下降，这是正常的生理变化</text>
              <text class="tips-item">• 所有指标的对照曲线已根据宝宝性别匹配对应的 WHO 标准</text>
            </view>
          </view>
        </view>
        
        <view class="who-section">
          <text class="who-label">温馨提示</text>
          <view class="tips-list">
            <text class="tips-item">1. 生长存在个体差异，P3-P97范围内均为正常</text>
            <text class="tips-item">2. 关注生长趋势比单一数值更重要</text>
            <text class="tips-item">3. 如数据持续异常，建议咨询医生</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 记录详情弹窗 -->
  <view class="popup-mask" wx:if="{{showDetailPopup}}" bindtap="hideDetailPopup">
    <view class="detail-popup" catchtap>
      <view class="popup-header">
        <text class="popup-title">记录详情</text>
        <view class="popup-close" bindtap="hideDetailPopup">
          <image src="/images/icons/x-mark.png" mode="aspectFit" />
        </view>
      </view>
      
      <view class="popup-content" wx:if="{{selectedRecord}}">
        <view class="detail-row">
          <text class="detail-label">测量日期</text>
          <text class="detail-value">{{selectedRecord.dateText}}</text>
        </view>
        
        <view class="detail-row" wx:if="{{selectedRecord.data.weight}}">
          <text class="detail-label">体重</text>
          <view class="detail-value-group">
            <text class="detail-value">{{selectedRecord.data.weight}} kg</text>
            <text class="detail-tag" wx:if="{{selectedRecord.percentile.weightP}}">P{{selectedRecord.percentile.weightP}}</text>
          </view>
        </view>
        
        <view class="detail-row" wx:if="{{selectedRecord.data.height}}">
          <text class="detail-label">身高</text>
          <view class="detail-value-group">
            <text class="detail-value">{{selectedRecord.data.height}} cm</text>
            <text class="detail-tag" wx:if="{{selectedRecord.percentile.heightP}}">P{{selectedRecord.percentile.heightP}}</text>
          </view>
        </view>
        
        <view class="detail-row" wx:if="{{selectedRecord.data.headCircumference}}">
          <text class="detail-label">头围</text>
          <view class="detail-value-group">
            <text class="detail-value">{{selectedRecord.data.headCircumference}} cm</text>
            <text class="detail-tag" wx:if="{{selectedRecord.percentile.headP}}">P{{selectedRecord.percentile.headP}}</text>
          </view>
        </view>
        
        <view class="detail-row" wx:if="{{selectedRecord.bmi}}">
          <text class="detail-label">BMI</text>
          <view class="detail-value-group">
            <text class="detail-value">{{selectedRecord.bmi}} kg/m²</text>
            <text class="detail-tag {{selectedRecord.bmiLevel}}" wx:if="{{selectedRecord.percentile.bmiP}}">P{{selectedRecord.percentile.bmiP}}</text>
            <text class="detail-tag" wx:else>{{selectedRecord.bmiStatus}}</text>
          </view>
        </view>
        
        <view class="detail-row" wx:if="{{selectedRecord.data.note}}">
          <text class="detail-label">备注</text>
          <text class="detail-value">{{selectedRecord.data.note}}</text>
        </view>
      </view>
      
      <view class="popup-footer">
        <view class="btn-edit" bindtap="editRecord">编辑</view>
        <view class="btn-delete" bindtap="deleteRecord">删除</view>
      </view>
    </view>
  </view>
</view>
