/* 疫苗追踪页样式 - 美拉德色彩风格 */

.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 待办疫苗区域 */
.todo-section {
  margin: 24rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.todo-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
}

.todo-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--white);
}

.todo-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.todo-scroll {
  white-space: nowrap;
}

.todo-cards {
  display: inline-flex;
  padding: 16rpx 16rpx 20rpx;
  gap: 12rpx;
}

.todo-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  padding: 20rpx 16rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  position: relative;
  border: 2rpx solid transparent;
}

.todo-card.overdue {
  background: rgba(232, 84, 84, 0.08);
  border-color: rgba(232, 84, 84, 0.3);
}

.todo-status {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

.status-badge {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-badge.overdue {
  background: var(--danger-color);
  color: var(--white);
}

.todo-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  white-space: normal;
  word-break: break-all;
}

.todo-dose {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.todo-date {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

.todo-card.overdue .todo-date {
  color: var(--danger-color);
}

.todo-action {
  margin-top: auto;
}

.action-btn {
  display: block;
  text-align: center;
  padding: 10rpx 0;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--white);
  font-size: 22rpx;
  border-radius: 20rpx;
}

.todo-card.overdue .action-btn {
  background: var(--danger-color);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--bg-secondary);
  margin: 24rpx;
  padding: 32rpx 16rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-value.done {
  color: var(--success-color);
}

.stat-value.pending {
  color: var(--accent-warm);
}

.stat-value.overdue {
  color: var(--danger-color);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: var(--shadow-soft);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.filter-tab.active {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--white);
  font-weight: 500;
}

/* 专业参考提示 */
.reference-tip {
  display: flex;
  align-items: center;
  margin: 0 24rpx 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(212, 165, 116, 0.1);
  border-radius: var(--radius-md);
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.7;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tip-arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 月龄分组 */
.age-group {
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.age-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
  margin-bottom: 12rpx;
}

.age-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.age-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: var(--bg-primary);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 疫苗卡片 */
.vaccine-cards {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vaccine-card {
  display: flex;
  align-items: center;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-soft);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.vaccine-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
}

.vaccine-card.status-done::before {
  background: var(--success-color);
}

.vaccine-card.status-overdue::before {
  background: var(--danger-color);
}

.vaccine-card.status-pending::before {
  background: var(--accent-warm);
}

.vaccine-card.status-done {
  background: linear-gradient(135deg, rgba(123, 201, 80, 0.05) 0%, rgba(123, 201, 80, 0.02) 100%);
}

.vaccine-card.status-overdue {
  background: linear-gradient(135deg, rgba(232, 84, 84, 0.05) 0%, rgba(232, 84, 84, 0.02) 100%);
}

.vaccine-status-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
}

.status-done .vaccine-status-icon {
  background: var(--success-color);
  color: var(--white);
}

.status-overdue .vaccine-status-icon {
  background: var(--danger-color);
  color: var(--white);
}

.status-pending .vaccine-status-icon {
  border: 2rpx solid var(--text-tertiary);
  color: var(--text-tertiary);
}

.vaccine-info {
  flex: 1;
}

.vaccine-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vaccine-note {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 400;
  padding: 2rpx 10rpx;
  background: var(--primary-color);
  color: var(--white);
  border-radius: 10rpx;
}

.vaccine-dose {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.vaccine-date {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.status-overdue .vaccine-date {
  color: var(--danger-color);
}

.vaccine-arrow {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vaccine-arrow text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 弹窗 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--mask-color-dark);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.detail-popup,
.date-popup {
  width: 100%;
  box-sizing: border-box;
  background: var(--bg-secondary);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
  animation: slideUp 0.3s ease;
  overflow: hidden;
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.popup-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-close text {
  font-size: 40rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.popup-content {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 详情区块 */
.detail-section {
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.detail-label {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.detail-key {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
  min-width: 0;
}

.detail-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex-shrink: 0;
  text-align: right;
  max-width: 65%;
  word-break: break-all;
}

.detail-value.done {
  color: var(--success-color);
}

.detail-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.detail-text.warning {
  color: var(--warning-color);
}

/* 弹窗底部 */
.popup-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.btn-action {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-action.primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--white);
}

.btn-action.secondary {
  background: var(--bg-primary);
  color: var(--text-primary);
}

.btn-action.danger {
  background: rgba(232, 84, 84, 0.1);
  color: var(--danger-color);
}

/* 日期选择器 */
.date-picker-content {
  height: 400rpx;
}

.date-picker-view {
  height: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-primary);
}
