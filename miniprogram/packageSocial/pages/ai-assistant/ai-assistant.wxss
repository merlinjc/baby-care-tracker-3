/* AI育儿助手页样式 */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-primary, #F5F1EB);
}

/* 配额横幅 */
.quota-banner {
  background: linear-gradient(135deg, rgba(212, 184, 150, 0.12) 0%, rgba(232, 220, 200, 0.18) 100%);
  margin: 24rpx 24rpx 0;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg, 32rpx);
  border: 1rpx solid rgba(212, 184, 150, 0.2);
  flex-shrink: 0;
}

.quota-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.quota-label {
  font-size: 24rpx;
  color: var(--text-secondary, #666666);
}

.quota-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-dark, #8B7B6B);
}

/* v4.0: 配额进度条 pill 圆角 */
.quota-bar {
  height: 8rpx;
  background: rgba(139, 123, 107, 0.1);
  border-radius: var(--radius-pill);
  overflow: hidden;
}

.quota-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color, #D4B896), var(--accent-color, #B8D4B8));
  border-radius: var(--radius-pill);
  transition: width 0.3s ease;
}

/* 相关性提示 */
.relevance-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(184, 212, 184, 0.12);
  border-radius: var(--radius-md, 24rpx);
  border: 1rpx solid rgba(184, 212, 184, 0.2);
  animation: tip-slide-in 0.3s ease;
}

@keyframes tip-slide-in {
  from {
    opacity: 0;
    transform: translateY(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-secondary, #666666);
  line-height: 1.4;
}

/* 评估卡片 */
.assessment-card {
  background: var(--bg-secondary, #FFFFFF);
  margin: 24rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg, 32rpx);
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
  flex-shrink: 0;
}

.assessment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.assessment-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #3D3D3D);
}

.assessment-score {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color, #D4B896);
}

.score-bar {
  height: 12rpx;
  background: var(--bg-primary, #F5F1EB);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color, #D4B896), var(--accent-color, #B8D4B8));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.analysis-item {
  display: flex;
  align-items: flex-start;
}

.analysis-bullet {
  color: var(--accent-color, #B8D4B8);
  margin-right: 12rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: var(--text-secondary, #666666);
  line-height: 1.5;
}

/* 快捷问题 */
.quick-questions {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 16rpx;
  flex-shrink: 0;
  overflow-x: auto;
}

.quick-item {
  flex-shrink: 0;
  background: var(--bg-secondary, #FFFFFF);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary, #666666);
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
  transition: all 0.2s ease;
}

.quick-item:active {
  transform: scale(0.95);
  background: var(--primary-light, #E8DCC8);
}

/* 对话区域 */
.chat-container {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.message {
  display: flex;
  align-items: flex-start;
  width: 100%;
  box-sizing: border-box;
}

.message.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-secondary, #FFFFFF);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
}

.avatar-icon {
  width: 40rpx;
  height: 40rpx;
}

.message-content {
  /* 计算最大宽度：100% - 头像(64rpx) - 左右边距(32rpx) = 剩余空间的85% */
  max-width: calc(100% - 96rpx);
  margin: 0 16rpx;
  box-sizing: border-box;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.message-text {
  display: block;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg, 32rpx);
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
  box-sizing: border-box;
}

.message.user .message-text {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  color: var(--white);
}

.message.assistant .message-text {
  background: var(--bg-secondary, #FFFFFF);
  color: var(--text-primary, #3D3D3D);
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
}

.message-text.typing {
  color: var(--text-hint, #999999);
  font-style: italic;
}

/* AI思考中样式 - 美拉德色系 */
.thinking-content {
  display: flex;
  flex-direction: column;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(212, 184, 150, 0.08) 0%, rgba(232, 220, 200, 0.12) 100%);
  border-radius: var(--radius-lg, 32rpx);
  border: 1rpx solid rgba(212, 184, 150, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(139, 123, 107, 0.06);
  box-sizing: border-box;
  width: fit-content;
  min-width: 200rpx;
}

.thinking-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.thinking-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(212, 184, 150, 0.2);
  border-top-color: var(--primary-color, #D4B896);
  border-radius: 50%;
  animation: thinking-spin 1s linear infinite;
}

@keyframes thinking-spin {
  to {
    transform: rotate(360deg);
  }
}

.thinking-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--primary-dark, #8B7B6B);
  letter-spacing: 1rpx;
}

.thinking-dots {
  display: flex;
  margin-top: 12rpx;
  margin-left: 52rpx;
}

.thinking-dots .dot {
  font-size: 32rpx;
  color: var(--primary-color, #D4B896);
  animation: dot-blink 1.4s infinite ease-in-out;
}

.thinking-dots .dot:nth-child(1) {
  animation-delay: 0s;
}

.thinking-dots .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.thinking-dots .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-blink {
  0%, 60%, 100% {
    opacity: 0.3;
  }
  30% {
    opacity: 1;
  }
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-secondary, #FFFFFF);
  border-top: 1rpx solid rgba(139, 123, 107, 0.1);
  flex-shrink: 0;
}

.message-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-primary, #F5F1EB);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--text-primary, #3D3D3D);
}

.send-btn {
  margin-left: 16rpx;
  padding: 16rpx 32rpx;
  background: var(--text-hint, #CCCCCC);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--white);
  transition: all 0.2s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
}

.send-btn:active {
  transform: scale(0.95);
}
