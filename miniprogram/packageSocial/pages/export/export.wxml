<!--数据导出页-->
<view class="page-container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 总记录数 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-number">{{totalRecords}}</text>
      <text class="stats-label">总记录数</text>
    </view>
  </view>

  <!-- 导出类型 -->
  <view class="section">
    <view class="section-title">选择导出类型</view>
    <view class="options-grid">
      <view 
        class="option-item {{item.checked ? 'checked' : ''}}" 
        wx:for="{{exportOptions}}" 
        wx:key="value" 
        bindtap="toggleOption" 
        data-value="{{item.value}}"
      >
        <text class="option-check">{{item.checked ? '✓' : '○'}}</text>
        <text class="option-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 日期范围 -->
  <view class="section">
    <view class="section-title">日期范围</view>
    <view class="range-tabs">
      <view 
        class="range-tab {{dateRange === 'week' ? 'active' : ''}}" 
        bindtap="onDateRangeChange" 
        data-range="week"
      >最近一周</view>
      <view 
        class="range-tab {{dateRange === 'month' ? 'active' : ''}}" 
        bindtap="onDateRangeChange" 
        data-range="month"
      >最近一月</view>
      <view 
        class="range-tab {{dateRange === 'all' ? 'active' : ''}}" 
        bindtap="onDateRangeChange" 
        data-range="all"
      >全部</view>
    </view>
  </view>

  <!-- 导出格式 -->
  <view class="section">
    <view class="section-title">导出格式</view>
    <view class="format-tabs">
      <view 
        class="format-tab {{exportFormat === 'csv' ? 'active' : ''}}" 
        bindtap="onFormatChange" 
        data-format="csv"
      >CSV 表格</view>
      <view 
        class="format-tab {{exportFormat === 'json' ? 'active' : ''}}" 
        bindtap="onFormatChange" 
        data-format="json"
      >JSON 数据</view>
    </view>
  </view>

  <!-- 导出按钮 -->
  <view class="export-btn {{loading ? 'disabled' : ''}}" bindtap="doExport">
    <text wx:if="{{!loading}}">导出数据</text>
    <text wx:else>导出中...</text>
  </view>

  <!-- 说明 -->
  <view class="tips-section">
    <text class="tips-title">说明</text>
    <text class="tips-text">• CSV格式可用Excel或Numbers打开</text>
    <text class="tips-text">• JSON格式适合开发者进行数据分析</text>
    <text class="tips-text">• 导出后可通过微信分享或保存</text>
  </view>
</view>
