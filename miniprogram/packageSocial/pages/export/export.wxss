/* 数据导出页样式 */
.page-container {
  min-height: 100vh;
  background: var(--bg-primary, #F5F1EB);
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  border-radius: var(--radius-lg, 32rpx);
  padding: 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(139, 123, 107, 0.2);
}

.stats-item {
  text-align: center;
}

.stats-number {
  display: block;
  font-size: 64rpx;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 区块 */
.section {
  background: var(--bg-secondary, #FFFFFF);
  border-radius: var(--radius-lg, 32rpx);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #3D3D3D);
  margin-bottom: 24rpx;
}

/* 选项网格 */
.options-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-primary, #F5F1EB);
  border-radius: var(--radius-md, 24rpx);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.checked {
  background: linear-gradient(135deg, rgba(212, 184, 150, 0.2) 0%, rgba(212, 184, 150, 0.1) 100%);
  border-color: var(--primary-color, #D4B896);
}

.option-check {
  font-size: 28rpx;
  color: var(--text-hint, #999999);
  margin-right: 12rpx;
}

.option-item.checked .option-check {
  color: var(--primary-color, #D4B896);
}

.option-label {
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
}

/* 日期范围 */
.range-tabs, .format-tabs {
  display: flex;
  gap: 16rpx;
}

.range-tab, .format-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: var(--bg-primary, #F5F1EB);
  border-radius: var(--radius-md, 24rpx);
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
  transition: all 0.2s ease;
}

.range-tab.active, .format-tab.active {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  color: var(--white);
  font-weight: 500;
}

/* 导出按钮 */
.export-btn {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  color: var(--white);
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  padding: 28rpx;
  border-radius: var(--radius-lg, 32rpx);
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 123, 107, 0.3);
  transition: all 0.2s ease;
}

.export-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.export-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 说明 */
.tips-section {
  background: var(--bg-secondary, #FFFFFF);
  border-radius: var(--radius-lg, 32rpx);
  padding: 32rpx;
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #3D3D3D);
  margin-bottom: 16rpx;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint, #999999);
  line-height: 1.8;
}
