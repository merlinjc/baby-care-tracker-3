/* 加入家庭页面样式 - 美拉德色彩风格 */
@import '../../../styles/page-header.wxss';
@import '../../../styles/form.wxss';

.family-join-container {
  padding: var(--spacing-lg);
  background: var(--bg-secondary);
  min-height: 100vh;
}

.code-input {
  text-transform: uppercase;
  text-align: center;
  letter-spacing: 8rpx;
  font-weight: 600;
}

/* 覆盖公共样式的 letter-spacing */
.input-placeholder {
  letter-spacing: 0;
}

/* 加入按钮 */
.join-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--white);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--gradient-end) 100%);
  border-radius: var(--radius-lg);
  border: none;
  margin-top: var(--spacing-lg);
  box-shadow: 0 8rpx 32rpx rgba(212, 184, 150, 0.4);
  transition: all var(--transition-fast);
}

.join-btn::after {
  border: none;
}

.join-btn:active {
  transform: scale(0.98);
}

.join-btn[disabled] {
  background: linear-gradient(135deg, var(--disabled-start) 0%, var(--disabled-end) 100%);
  box-shadow: none;
  opacity: 0.6;
}

/* 提示区域 */
.tip-section {
  margin-top: var(--spacing-xxl);
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-md);
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.1) 0%, 
    rgba(184, 212, 184, 0.1) 100%
  );
  border-radius: var(--radius-md);
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.tip-icon image {
  width: 100%;
  height: 100%;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}
