<!--设置页-->
<view class="page-container {{darkMode ? 'dark-mode' : ''}} {{themeTransition ? 'theme-transition' : ''}}">
  <!-- 通知设置 -->
  <view class="section">
    <view class="section-title">通知设置</view>
    
    <view class="setting-item">
      <text class="setting-label">推送通知</text>
      <switch 
        checked="{{settings.notification}}" 
        color="#D4B896" 
        bindchange="toggleSetting" 
        data-key="notification"
      />
    </view>
  </view>

  <!-- 提醒设置 -->
  <view class="section">
    <view class="section-title">提醒设置</view>
    
    <view class="setting-item">
      <text class="setting-label">喂养提醒</text>
      <switch 
        checked="{{settings.feedingReminder}}" 
        color="#D4B896" 
        bindchange="toggleSetting" 
        data-key="feedingReminder"
      />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">睡眠提醒</text>
      <switch 
        checked="{{settings.sleepReminder}}" 
        color="#D4B896" 
        bindchange="toggleSetting" 
        data-key="sleepReminder"
      />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">排便提醒</text>
      <switch 
        checked="{{settings.diaperReminder}}" 
        color="#D4B896" 
        bindchange="toggleSetting" 
        data-key="diaperReminder"
      />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">体温异常警报</text>
      <switch 
        checked="{{settings.temperatureAlert}}" 
        color="#D4B896" 
        bindchange="toggleSetting" 
        data-key="temperatureAlert"
      />
    </view>
  </view>

  <!-- 显示设置 -->
  <view class="section">
    <view class="section-title">显示设置</view>
    
    <view class="theme-options">
      <view class="theme-option {{themeMode === 'light' ? 'active' : ''}}"
            data-mode="light" bindtap="onThemeSelect">
        <view class="theme-icon-wrapper theme-icon-light">
          <text class="theme-icon-text">☀</text>
        </view>
        <text class="theme-option-label">亮色</text>
      </view>
      <view class="theme-option {{themeMode === 'dark' ? 'active' : ''}}"
            data-mode="dark" bindtap="onThemeSelect">
        <view class="theme-icon-wrapper theme-icon-dark">
          <text class="theme-icon-text">🌙</text>
        </view>
        <text class="theme-option-label">暖夜</text>
      </view>
      <view class="theme-option {{themeMode === 'system' ? 'active' : ''}}"
            data-mode="system" bindtap="onThemeSelect">
        <view class="theme-icon-wrapper theme-icon-system">
          <text class="theme-icon-text">⚙</text>
        </view>
        <text class="theme-option-label">跟随系统</text>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section">
    <view class="section-title">数据管理</view>
    
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-label">清除缓存</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item danger-item" bindtap="clearAllCloudData">
      <text class="menu-label danger-text">清除云端数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-title">关于</view>
    
    <view class="menu-item" bindtap="viewPrivacy">
      <text class="menu-label">隐私政策</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="viewTerms">
      <text class="menu-label">用户协议</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="giveFeedback">
      <text class="menu-label">反馈建议</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
