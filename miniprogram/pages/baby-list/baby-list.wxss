/* 宝宝管理页样式 */
.page-container {
  min-height: 100vh;
  background: var(--bg-primary, #F5F1EB);
  padding: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 宝宝卡片 */
.baby-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.baby-card {
  background: var(--bg-secondary, #FFFFFF);
  border-radius: var(--radius-lg, 32rpx);
  overflow: hidden;
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
  transition: all 0.2s ease;
}

.baby-card.current {
  border: 2rpx solid var(--primary-color, #D4B896);
  background: linear-gradient(135deg, rgba(212, 184, 150, 0.1) 0%, var(--bg-secondary) 100%);
}

.baby-main {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.baby-main:active {
  background: var(--bg-primary, #F5F1EB);
}

.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid var(--primary-light, #E8DCC8);
}

.baby-info {
  flex: 1;
}

.baby-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.baby-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary, #3D3D3D);
  margin-right: 12rpx;
}

.gender-icon {
  width: 36rpx;
  height: 36rpx;
}

.baby-age {
  font-size: 26rpx;
  color: var(--text-secondary, #666666);
}

.current-badge {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  color: var(--white);
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 操作按钮 */
.baby-actions {
  display: flex;
  border-top: 1rpx solid rgba(139, 123, 107, 0.1);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  background: var(--bg-primary, #F5F1EB);
}

.action-btn.danger .action-text {
  color: var(--temperature-color, #D4A8A8);
}

.action-text {
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint, #999999);
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  color: var(--white);
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 32rpx;
}

/* 添加按钮 */
.add-button {
  position: fixed;
  left: 50%;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 123, 107, 0.3);
}

.add-icon {
  font-size: 36rpx;
  color: var(--white);
  margin-right: 12rpx;
}

.add-text {
  font-size: 30rpx;
  color: var(--white);
  font-weight: 500;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint, #999999);
}
