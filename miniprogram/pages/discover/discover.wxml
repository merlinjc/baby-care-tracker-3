<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- v4.0: 页头（保留图标 — 发现页品牌辨识度） -->
  <view class="page-header">
    <view class="header-icon">
      <image src="/images/icons/compass.png" mode="aspectFit"></image>
    </view>
    <view class="header-text">
      <text class="header-title">发现更多</text>
      <text class="header-subtitle">科学育儿，温暖陪伴</text>
    </view>
  </view>

  <!-- v4.0: 聚焦卡片（最紧急的一项待办） -->
  <view class="focus-section" wx:if="{{focusItem}}">
    <focus-card
      type="{{focusItem.type}}"
      title="{{focusItem.title}}"
      description="{{focusItem.description}}"
      icon="{{focusItem.icon}}"
      urgency="{{focusItem.urgency}}"
      target-url="{{focusItem.targetUrl}}"
      dark-mode="{{darkMode}}"
    />
  </view>

  <!-- v4.0: 功能入口 2x2 网格 -->
  <view class="tool-grid">
    <view 
      class="tool-item"
      wx:for="{{toolItems}}"
      wx:key="title"
      data-url="{{item.url}}"
      bindtap="goToPage"
    >
      <view class="tool-icon-wrapper" style="background: {{item.bgColor}};">
        <image class="tool-icon" src="{{item.icon}}" mode="aspectFit" lazy-load></image>
      </view>
      <text class="tool-title">{{item.title}}</text>
      <view class="tool-badge" wx:if="{{item.badge > 0}}">{{item.badge}}</view>
    </view>
  </view>

  <!-- v4.0: 专业参考标准（精简列表行） -->
  <view class="reference-section">
    <view class="section-header">
      <text class="section-title">专业参考标准</text>
    </view>
    
    <view class="reference-list">
      <view class="reference-row" bindtap="showWhoInfo">
        <view class="ref-badge who">WHO</view>
        <text class="ref-name">WHO 儿童生长标准</text>
        <image class="ref-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load></image>
      </view>
      <view class="reference-row" bindtap="showCdcInfo">
        <view class="ref-badge cdc">CDC</view>
        <text class="ref-name">CDC 发育里程碑</text>
        <image class="ref-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load></image>
      </view>
      <view class="reference-row" bindtap="showChinaInfo">
        <view class="ref-badge cn">CN</view>
        <text class="ref-name">国家免疫规划</text>
        <image class="ref-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load></image>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">数据来源：WHO、CDC、中国疾控中心</text>
  </view>
  
  <!-- v4.0: 专业参考弹窗（底部弹出） -->
  <view class="popup-mask {{showInfoPopup ? 'popup-mask-visible' : ''}}" wx:if="{{showInfoPopup}}" bindtap="hideInfoPopup">
    <view class="popup-container {{showInfoPopup ? 'popup-enter' : ''}}" catchtap>
      <view class="swipe-indicator"></view>
      <view class="popup-header">
        <view class="popup-icon">
          <image src="/images/icons/compass.png" mode="aspectFit" />
        </view>
        <text class="popup-title">{{infoPopupData.title}}</text>
        <view class="popup-close" bindtap="hideInfoPopup">
          <image src="/images/icons/x-mark.png" mode="aspectFit" />
        </view>
      </view>
      <scroll-view class="popup-content" scroll-y>
        <view class="popup-inner">
          <view class="info-section">
            <text class="info-label">数据来源</text>
            <text class="info-text">{{infoPopupData.source}}</text>
          </view>
          <view class="info-section">
            <text class="info-label">适用范围</text>
            <text class="info-text">{{infoPopupData.scope}}</text>
          </view>
          <view class="info-section">
            <text class="info-label">主要用途</text>
            <text class="info-text">{{infoPopupData.usage}}</text>
          </view>
          <view class="info-section">
            <text class="info-label">注意事项</text>
            <text class="info-text">{{infoPopupData.note}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
  
</view>
