/* 发现页样式 - v4.0 重构 */
@import '../../styles/popup.wxss';

/* 页面容器 */
.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 0 0 env(safe-area-inset-bottom);
}

/* 页面标题（保留 header-icon — 发现页品牌辨识度） */
.page-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.2) 0%, 
    rgba(184, 212, 184, 0.2) 100%
  );
  border-radius: var(--radius-lg);
}

.header-icon image {
  width: 48rpx;
  height: 48rpx;
}

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ============ v4.0 聚焦卡片 ============ */
.focus-section {
  padding: 0 var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

/* ============ v4.0 功能入口 2x2 网格 ============ */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
  position: relative;
}

.tool-item:active {
  transform: scale(0.97);
}

.tool-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tool-icon {
  width: 44rpx;
  height: 44rpx;
}

.tool-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.tool-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: var(--danger-color);
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ============ v4.1.1 FR-3: 占位引导卡片 ============ */
.tool-item--placeholder {
  opacity: 0.55;
  border: 2rpx dashed var(--border-color);
  box-shadow: none;
  background: transparent;
}

.tool-item--placeholder:active {
  transform: none;
}

.tool-subtitle {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* ============ v4.0 专业参考标准（精简列表行） ============ */
.section-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-lg);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.reference-section {
  margin-bottom: var(--spacing-md);
}

.reference-list {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  margin: 0 var(--spacing-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.reference-row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.2s ease;
}

.reference-row:last-child {
  border-bottom: none;
}

.reference-row:active {
  background: rgba(212, 184, 150, 0.06);
}

.ref-badge {
  width: 56rpx;
  height: 36rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--white);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.ref-badge.who {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
}

.ref-badge.cdc {
  background: linear-gradient(135deg, #5BC0DE, #46B8DA);
}

.ref-badge.cn {
  background: linear-gradient(135deg, #E74C3C, #C0392B);
}

.ref-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.ref-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
  flex-shrink: 0;
}

/* ============ 底部提示 ============ */
.footer-tip {
  text-align: center;
  padding: var(--spacing-xxl) 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ============ v4.0 弹窗内容样式 ============ */
.info-section {
  padding: var(--spacing-md);
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
}

.info-section:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
  display: block;
  margin-bottom: var(--spacing-xs);
}

.info-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  white-space: pre-wrap;
}
