/* 使用指南页样式 */
.page-container {
  min-height: 100vh;
  background: var(--bg-primary, #F5F1EB);
  padding: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 顶部介绍 */
.header-section {
  text-align: center;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--text-primary, #3D3D3D);
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary, #666666);
}

/* 指南区块 */
.guide-section {
  background: var(--bg-secondary, #FFFFFF);
  border-radius: var(--radius-lg, 32rpx);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card, 0 4rpx 24rpx rgba(139, 123, 107, 0.08));
}

.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, rgba(212, 184, 150, 0.15) 0%, rgba(232, 220, 200, 0.1) 100%);
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary, #3D3D3D);
}

/* 指南项 */
.guide-items {
  padding: 8rpx 0;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 32rpx;
}

.guide-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--primary-color, #D4B896);
  border-radius: 50%;
  margin-top: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.guide-content {
  flex: 1;
}

.guide-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary, #3D3D3D);
  margin-bottom: 8rpx;
}

.guide-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary, #666666);
  line-height: 1.5;
}

/* 底部 */
.footer-section {
  text-align: center;
  padding: 32rpx;
}

.footer-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-hint, #999999);
  margin-bottom: 24rpx;
}

.footer-btn {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary-color, #D4B896), var(--primary-dark, #8B7B6B));
  color: var(--white);
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 32rpx;
}
