<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- FR-15: 骨架屏加载态 -->
  <view wx:if="{{loading}}" class="skeleton-container">
    <view class="skeleton-block skeleton-greeting"></view>
    <view class="skeleton-block skeleton-baby-card"></view>
    <view class="skeleton-block skeleton-status-banner"></view>
    <view class="skeleton-block skeleton-todo"></view>
    <view class="skeleton-block skeleton-overview"></view>
    <view class="skeleton-block skeleton-actions"></view>
    <view class="skeleton-block skeleton-timeline"></view>
  </view>

  <!-- 错误状态 -->
  <error-state 
    wx:elif="{{error}}" 
    message="{{errorMsg}}"
    bind:retry="onRetry"
  />

  <!-- 正常内容 - 带渐显动画 -->
  <block wx:elif="{{currentBaby}}">
    <view class="content-container">
      <!-- v4.0 区域 A: 问候区（合并多宝切换） -->
      <view class="greeting-bar">
        <view class="greeting-left">
          <view class="greeting-main">
            <text class="greeting-text">{{greeting}}，</text>
            <text class="greeting-baby-name" wx:if="{{currentBaby.nickName}}">{{currentBaby.nickName}}</text>
          </view>
          <view class="greeting-sub">
            <text class="greeting-days" wx:if="{{birthDayCount > 0}}">出生第 {{birthDayCount}} 天</text>
          </view>
        </view>
        <view class="greeting-right">
          <text class="greeting-date">{{todayDateText}}</text>
          <!-- 多宝头像组（仅多宝时显示） -->
          <view class="greeting-avatars" wx:if="{{familyBabies.length > 1}}">
            <block wx:for="{{familyBabies}}" wx:key="_id">
              <view 
                wx:if="{{index < 3}}"
                class="greeting-avatar {{item._id === currentBaby._id ? 'active' : ''}}"
                data-baby-id="{{item._id}}"
                bindtap="switchBaby"
              >
                <image src="{{item.avatarUrl || '/images/default-baby.png'}}" mode="aspectFill" lazy-load></image>
              </view>
            </block>
            <view class="greeting-avatar-more" wx:if="{{familyBabies.length > 3}}">
              <text>+{{familyBabies.length - 3}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- EE-5/EE-7: 月龄/节日提示条（保留不变） -->
      <view class="egg-banner" wx:if="{{easterEggBanner.show}}" 
            style="animation: eggSlideDown 0.3s ease forwards;">
        <image class="egg-banner-icon" src="{{easterEggBanner.icon}}" mode="aspectFit" />
        <text class="egg-banner-text">{{easterEggBanner.text}}</text>
        <view class="egg-banner-close" bindtap="closeEasterEggBanner">
          <text>×</text>
        </view>
      </view>

      <!-- v4.0 区域 B: 状态胶囊（核心交互升级） -->
      <view class="status-capsule {{activeSleep ? (sleepAbnormal ? 'capsule-abnormal' : 'capsule-sleeping') : 'capsule-default'}}" 
            wx:if="{{activeStatus.type !== 'none' || activeSleep}}">
        <image class="capsule-icon" 
               src="{{sleepAbnormal ? '/images/icons/warning.png' : (activeStatus.type === 'sleeping' ? '/images/icons/sleep-color.png' : (activeStatus.type === 'feeding_ago' ? '/images/icons/feeding-color.png' : '/images/icons/record-color.png'))}}" 
               mode="aspectFit"></image>
        <text class="capsule-text">{{activeStatus.text}}</text>
        <!-- 录制指示灯 -->
        <view class="rec-indicator" wx:if="{{activeSleep && !sleepAbnormal}}">
          <image class="rec-dot" src="/images/icons/rec-dot.png" mode="aspectFit"></image>
          <text class="rec-label">REC</text>
        </view>
        <!-- 操作按钮 -->
        <view class="capsule-action" wx:if="{{activeSleep && !sleepAbnormal}}" catchtap="endSleepFromBanner">
          <text>结束</text>
        </view>
        <view class="capsule-action capsule-action-danger" wx:if="{{sleepAbnormal}}" catchtap="cancelAbnormalSleep">
          <text>取消计时</text>
        </view>
      </view>

      <!-- v4.0 区域 E: 今日待办（竖向条） -->
      <view class="todo-list-card" wx:if="{{todoStats.total > 0}}">
        <!-- 待办条目（最多3条） -->
        <view class="todo-row {{item.isOverdue ? 'overdue' : (item.isUpcoming ? 'upcoming' : '')}}"
              wx:for="{{todoStats.vaccineItems}}" wx:key="name" wx:if="{{index < 3}}"
              bindtap="goToVaccine">
          <view class="todo-row-bar vaccine {{item.isOverdue ? 'overdue' : ''}}"></view>
          <image class="todo-row-icon" src="/images/icons/vaccine-color.png" mode="aspectFit" lazy-load></image>
          <view class="todo-row-text">
            <text class="todo-row-title">{{item.name}}</text>
            <text class="todo-row-sub">·</text>
            <text class="todo-row-sub">{{item.dose}}</text>
          </view>
          <view class="todo-row-tag {{item.isOverdue ? 'tag-overdue' : 'tag-upcoming'}}" wx:if="{{item.isOverdue || item.isUpcoming}}">
            {{item.isOverdue ? '已逾期' : '即将'}}
          </view>
        </view>
        <view class="todo-row {{item.isOverdue ? 'overdue' : ''}}"
              wx:for="{{todoStats.milestoneItems}}" wx:key="name" wx:if="{{index < 3 - todoStats.vaccineItems.length}}"
              bindtap="goToMilestone">
          <view class="todo-row-bar milestone {{item.isOverdue ? 'overdue' : ''}}"></view>
          <image class="todo-row-icon" src="/images/icons/milestone-color.png" mode="aspectFit" lazy-load></image>
          <view class="todo-row-text">
            <text class="todo-row-title">{{item.name}}</text>
            <text class="todo-row-sub">·</text>
            <text class="todo-row-sub">{{item.category}}</text>
          </view>
          <view class="todo-row-tag tag-overdue" wx:if="{{item.isOverdue}}">已逾期</view>
        </view>
        <!-- 查看全部 -->
        <view class="todo-view-all" wx:if="{{todoStats.total > 3}}" bindtap="goToDiscover">
          <text>查看全部 {{todoStats.total}} 项</text>
          <image src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load style="width:20rpx;height:20rpx;opacity:0.6;"></image>
        </view>
      </view>

      <!-- v4.0 区域 C: 今日摘要（48rpx 大数字 + 进度条 + 点击弹窗） -->
      <view class="card overview-card">
        <view class="title">今日概览</view>
        
        <!-- 发烧警示横条 -->
        <view class="fever-alert" wx:if="{{showFeverAlert}}">
          <image class="fever-alert-icon" src="/images/icons/warning.png" mode="aspectFit" lazy-load></image>
          <text class="fever-alert-text">宝宝{{tempStatusText}}，请注意观察</text>
        </view>
        
        <view class="stats-grid">
          <!-- 喂养 -->
          <view class="stat-item" data-type="feeding" bindtap="onStatTap">
            <view class="stat-icon-wrapper feeding">
              <image class="stat-icon" src="/images/icons/feeding-color.png" mode="aspectFit"></image>
            </view>
            <view class="stat-value">{{todayStats.feeding.count}}</view>
            <view class="stat-unit">次</view>
            <view class="stat-detail" wx:if="{{todayStats.feeding.totalAmount > 0}}">{{todayStats.feeding.totalAmount}}ml</view>
            <view class="stat-progress">
              <view class="stat-progress-fill feeding" style="--progress-target: {{feedingProgress}}%;"></view>
            </view>
          </view>

          <!-- 睡眠 -->
          <view class="stat-item" data-type="sleep" bindtap="onStatTap">
            <view class="stat-icon-wrapper sleep">
              <image class="stat-icon" src="/images/icons/sleep-color.png" mode="aspectFit"></image>
            </view>
            <view class="stat-value sleep-value">
              {{sleepDisplay || '0m'}}
              <image class="goal-check" wx:if="{{sleepGoalMet}}" src="/images/icons/check-circle.png" mode="aspectFit" lazy-load></image>
            </view>
            <view class="stat-unit">{{todayStats.sleep.count}}次</view>
            <view class="stat-progress">
              <view class="stat-progress-fill sleep" style="--progress-target: {{sleepProgress}}%;"></view>
            </view>
          </view>

          <!-- 排便 -->
          <view class="stat-item" data-type="diaper" bindtap="onStatTap">
            <view class="stat-icon-wrapper diaper">
              <image class="stat-icon" src="/images/icons/diaper-color.png" mode="aspectFit"></image>
            </view>
            <view class="stat-value">{{todayStats.diaper.count}}</view>
            <view class="stat-unit">次</view>
            <view class="stat-detail">湿{{todayStats.diaper.wet}} 脏{{todayStats.diaper.dirty}}</view>
            <view class="stat-progress">
              <view class="stat-progress-fill diaper" style="--progress-target: {{diaperProgress}}%;"></view>
            </view>
          </view>

          <!-- 体温 -->
          <view class="stat-item" data-type="temperature" bindtap="onStatTap">
            <view class="stat-icon-wrapper temperature">
              <image class="stat-icon" src="/images/icons/temperature.png" mode="aspectFit"></image>
            </view>
            <view class="stat-value temp-value" style="color: {{tempColor}};">{{tempDisplayText}}</view>
            <view class="stat-unit">{{tempStatus !== 'none' ? tempStatusText : (todayStats.temperature.count + '次')}}</view>
            <view class="stat-progress-placeholder"></view>
          </view>
        </view>
      </view>

  <!-- FR-8/9: 快捷入口（横向滚动 5 格，含喂养预测角标） - 仅 editor/admin 可见 -->
  <view class="quick-section" wx:if="{{canEdit}}">
    <view class="quick-section-title">快捷记录</view>
  </view>
  <scroll-view class="quick-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{canEdit}}">
    <view class="quick-scroll-inner">
      <!-- 喂养（含 FR-8 预测角标） -->
      <view class="action-btn feeding" bindtap="openFeedingPopup">
        <view class="action-badge prediction" wx:if="{{feedingPrediction.show && !feedingPrediction.urgent}}">
          {{feedingPrediction.text}}
        </view>
        <view class="action-badge urgent" wx:if="{{feedingPrediction.show && feedingPrediction.urgent}}">
          {{feedingPrediction.text}}
        </view>
        <view class="action-icon-wrapper">
          <image class="action-icon" src="/images/icons/feeding-white.png" mode="aspectFit"></image>
        </view>
        <view class="action-text">喂养</view>
      </view>

      <!-- FR-10: 睡眠（三态：正常/计时中脉冲动画/异常>24h） -->
      <view class="action-btn sleep {{activeSleep ? (sleepAbnormal ? 'abnormal' : 'timing') : ''}}" bindtap="{{activeSleep ? 'endSleepFromBanner' : 'openSleepPopup'}}">
        <view class="timing-indicator" wx:if="{{activeSleep && !sleepAbnormal}}">
          <view class="timing-dot"></view>
        </view>
        <view class="action-icon-wrapper">
          <image class="action-icon" src="/images/icons/sleep-white.png" mode="aspectFit"></image>
        </view>
        <view class="action-text">{{activeSleep ? (sleepAbnormal ? '异常' : activeSleepDisplay) : '睡眠'}}</view>
      </view>

      <!-- 排便 -->
      <view class="action-btn diaper" bindtap="openDiaperPopup">
        <view class="action-icon-wrapper">
          <image class="action-icon" src="/images/icons/diaper-white.png" mode="aspectFit"></image>
        </view>
        <view class="action-text">排便</view>
      </view>

      <!-- 体温 -->
      <view class="action-btn temperature" bindtap="openTemperaturePopup">
        <view class="action-icon-wrapper">
          <image class="action-icon" src="/images/icons/temperature-white.png" mode="aspectFit"></image>
        </view>
        <view class="action-text">体温</view>
      </view>

      <!-- FR-9: 生长入口 -->
      <view class="action-btn growth" bindtap="openGrowthPopup">
        <view class="action-icon-wrapper">
          <image class="action-icon" src="/images/icons/growth-white.png" mode="aspectFit"></image>
        </view>
        <view class="action-text">生长</view>
      </view>
    </view>
  </scroll-view>

  <!-- Viewer 角色提示条 -->
  <view class="viewer-hint-bar" wx:if="{{!canEdit && userRole === 'viewer'}}">
    <image class="viewer-hint-icon" src="/images/icons/visible.png" mode="aspectFit" lazy-load></image>
    <text class="viewer-hint-text">当前为仅查看权限，如需添加记录请联系管理员</text>
  </view>

  <!-- FR-11/12: 时间线（限 5 条 + 查看全部） -->
  <view class="card timeline-card">
    <view class="timeline-header">
      <view class="title">今日记录</view>
      <text class="timeline-count" wx:if="{{totalTodayCount > 0}}">{{totalTodayCount}}条</text>
    </view>
    <timeline 
      records="{{recentRecords}}" 
      swipe-enabled="{{canEdit}}"
      bind:swipeEdit="onTimelineEdit"
      bind:swipeDelete="onTimelineDelete"
    />
    <!-- FR-12: 查看全部按钮 -->
    <view class="view-all-btn" wx:if="{{totalTodayCount > 5}}" bindtap="goToRecordList">
      <text>查看全部 {{totalTodayCount}} 条今日记录</text>
      <image class="view-all-arrow" src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load></image>
    </view>
  </view>
  </view>

  <!-- 喂养弹窗 -->
  <feeding-popup 
    id="feedingPopup"
    show="{{showFeedingPopup}}"
    dark-mode="{{darkMode}}"
    bind:close="closeFeedingPopup"
    bind:created="onRecordCreated"
  />

  <!-- 睡眠弹窗 -->
  <sleep-popup 
    id="sleepPopup"
    show="{{showSleepPopup}}"
    dark-mode="{{darkMode}}"
    bind:close="closeSleepPopup"
    bind:created="onRecordCreated"
  />

  <!-- 排便弹窗 -->
  <diaper-popup 
    id="diaperPopup"
    show="{{showDiaperPopup}}"
    dark-mode="{{darkMode}}"
    bind:close="closeDiaperPopup"
    bind:created="onRecordCreated"
  />

  <!-- 体温弹窗 -->
  <temperature-popup 
    id="temperaturePopup"
    show="{{showTemperaturePopup}}"
    dark-mode="{{darkMode}}"
    bind:close="closeTemperaturePopup"
    bind:created="onRecordCreated"
  />

  <!-- FR-9: 生长弹窗 -->
  <growth-popup 
    show="{{showGrowthPopup}}"
    baby-id="{{currentBaby._id}}"
    dark-mode="{{darkMode}}"
    bind:close="closeGrowthPopup"
    bind:saved="onGrowthSaved"
  />

  <!-- 彩蛋弹窗 -->
  <easter-egg-popup
    show="{{easterEggPopup.show}}"
    type="{{easterEggPopup.type}}"
    egg-data="{{easterEggPopup.eggData}}"
    dark-mode="{{darkMode}}"
    storage-key="{{easterEggPopup.storageKey}}"
    baby-id="{{currentBaby._id}}"
    bind:close="onEasterEggPopupClose"
  />

  <!-- 彩蛋 Toast -->
  <easter-egg-toast
    show="{{easterEggToast.show}}"
    text="{{easterEggToast.text}}"
    icon="{{easterEggToast.icon}}"
    dark-mode="{{darkMode}}"
    storage-key="{{easterEggToast.storageKey}}"
    bind:close="onEasterEggToastClose"
  />

  </block>

  <!-- 无宝宝数据提示 -->
  <view wx:if="{{!loading && !error && !currentBaby}}" class="empty-state">
    <text class="empty-text">请先添加宝宝信息</text>
    <button class="add-baby-btn" bindtap="goToBabyCreate">添加宝宝</button>
  </view>
</view>
