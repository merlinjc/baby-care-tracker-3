/* 首页样式 - 美拉德色彩风格 */

/* ============ FR-15: 首页专属 CSS 变量扩展 ============ */
page {
  /* 状态横幅背景 (FR-1) */
  --status-sleeping-bg: rgba(184, 168, 212, 0.12);   /* sleep-color 透明版 */
  --status-feeding-bg:  rgba(168, 212, 168, 0.12);   /* feeding-color 透明版 */
  --status-default-bg:  rgba(212, 184, 150, 0.08);   /* primary-color 透明版 */

  /* AI 洞察卡片 (FR-14) */
  --insight-bg: linear-gradient(135deg, rgba(212, 184, 150, 0.06) 0%, rgba(248, 244, 238, 1) 100%);
  --insight-border: rgba(212, 184, 150, 0.2);

  /* 今日待办卡片 (FR-7) */
  --todo-vaccine-bg:    rgba(212, 136, 61, 0.1);
  --todo-milestone-bg:  rgba(123, 169, 201, 0.1);
  --todo-overdue-bg:    rgba(232, 84, 84, 0.1);

  /* 喂养预测角标 (FR-8) */
  --badge-prediction-bg:  rgba(168, 212, 168, 0.9);
  --badge-urgent-bg:      var(--warning-color, #D4883D);

  /* 体温警示横条 (FR-6) */
  --fever-alert-bg:     rgba(232, 84, 84, 0.08);
  --fever-alert-border: rgba(232, 84, 84, 0.3);
  --fever-alert-text:   var(--danger-color, #E85454);

  /* 骨架屏颜色 (FR-15) */
  --skeleton-base: rgba(212, 184, 150, 0.15);
  --skeleton-highlight: rgba(212, 184, 150, 0.25);
}

/* ============ FR-15: 骨架屏动画 ============ */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

.skeleton-block {
  background: linear-gradient(
    90deg,
    var(--skeleton-base) 25%,
    var(--skeleton-highlight) 50%,
    var(--skeleton-base) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 12rpx;
}

/* 骨架屏容器 */
.skeleton-container {
  padding: 32rpx;
  opacity: 1;
  transition: opacity 0.3s ease-out;
}

/* 骨架屏 - 问候语区域 */
.skeleton-greeting {
  height: 96rpx;
  margin-bottom: 24rpx;
}

/* 骨架屏 - 宝宝卡片区域 */
.skeleton-baby-card {
  height: 180rpx;
  margin-bottom: 24rpx;
}

/* 骨架屏 - 状态横幅 */
.skeleton-status-banner {
  height: 80rpx;
  margin-bottom: 24rpx;
}

/* 骨架屏 - 待办区域 */
.skeleton-todo {
  height: 120rpx;
  margin-bottom: 24rpx;
}

/* 骨架屏 - 今日概览 */
.skeleton-overview {
  height: 240rpx;
  margin-bottom: 24rpx;
}

/* 骨架屏 - 快捷操作 */
.skeleton-actions {
  height: 160rpx;
  margin-bottom: 24rpx;
}

/* 骨架屏 - 时间线 */
.skeleton-timeline {
  height: 320rpx;
}

/* 内容区渐显动画 */
.content-container {
  opacity: 0;
  animation: fadeIn 0.3s ease-out forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* ============ v4.0 区域 A: 问候区（合并多宝切换） ============ */
.greeting-bar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.greeting-left {
  flex: 1;
  min-width: 0;
}

.greeting-main {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 4rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.greeting-baby-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.greeting-sub {
  margin-top: 6rpx;
}

.greeting-days {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.greeting-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.greeting-date {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 多宝头像组 — 重叠排列 */
.greeting-avatars {
  display: flex;
  align-items: center;
}

.greeting-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid var(--bg-secondary);
  margin-left: -10rpx;
  transition: border-color 0.2s ease;
}

.greeting-avatar:first-child {
  margin-left: 0;
}

.greeting-avatar.active {
  border-color: var(--primary-color);
  box-shadow: 0 2rpx 8rpx rgba(212, 184, 150, 0.4);
}

.greeting-avatar image {
  width: 100%;
  height: 100%;
}

.greeting-avatar-more {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -10rpx;
  border: 2rpx solid var(--bg-secondary);
}

.greeting-avatar-more text {
  font-size: 20rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* ============ v4.0 区域 B: 状态胶囊 ============ */
.status-capsule {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-md);
  transition: background-color 0.3s ease;
  animation: capsuleTransition 0.3s ease;
  position: relative;
}

.status-capsule.capsule-default {
  background: rgba(212, 184, 150, 0.08);
}

.status-capsule.capsule-sleeping {
  background: rgba(184, 168, 212, 0.12);
}

.status-capsule.capsule-abnormal {
  background: rgba(232, 84, 84, 0.10);
}

.capsule-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.capsule-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  flex: 1;
}

/* 录制指示灯 */
.rec-indicator {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-right: 16rpx;
}

.rec-dot {
  width: 12rpx;
  height: 12rpx;
  animation: recPulse 1.5s ease-in-out infinite;
}

.rec-label {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--danger-color);
  letter-spacing: 1rpx;
}

/* 胶囊操作按钮 */
.capsule-action {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-color);
  color: var(--white);
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.capsule-action:active {
  opacity: 0.85;
}

.capsule-action-danger {
  background: var(--danger-color);
}

/* 暗色模式胶囊覆盖 */
.dark-mode .status-capsule.capsule-default {
  background: rgba(212, 184, 150, 0.10);
}

.dark-mode .status-capsule.capsule-sleeping {
  background: rgba(148, 136, 180, 0.15);
}

.dark-mode .status-capsule.capsule-abnormal {
  background: rgba(212, 72, 72, 0.12);
}

.container {
  padding: 32rpx;
  background: var(--bg-primary);
  min-height: 100vh;
}

/* 卡片通用样式 */
.card {
  background: var(--bg-secondary);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 123, 107, 0.08);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* ============ FR-3/4/5/6: 今日概览增强 ============ */
.overview-card {
  position: relative;
}

/* FR-6: 发烧警示横条 */
.fever-alert {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  background: var(--fever-alert-bg);
  border: 1rpx solid var(--fever-alert-border);
  border-radius: 12rpx;
}

.fever-alert-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.fever-alert-text {
  font-size: 24rpx;
  color: var(--fever-alert-text);
  font-weight: 500;
}

/* 今日概览统计网格 — v4.0: gap 16rpx */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx 16rpx;
  background: var(--bg-primary);
  border-radius: 20rpx;
  transition: transform 0.3s ease, background-color 0.3s ease;
  position: relative;
}

.stat-item:active {
  transform: scale(0.98);
  background: rgba(212, 184, 150, 0.1);
}

/* v4.0: 图标容器 64rpx 圆形 */
.stat-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.stat-icon-wrapper.feeding { background: var(--feeding-bg); }
.stat-icon-wrapper.sleep { background: var(--sleep-bg); }
.stat-icon-wrapper.diaper { background: var(--diaper-bg); }
.stat-icon-wrapper.temperature { background: var(--temperature-bg); }

.stat-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

/* v4.0: 主数字 48rpx */
.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  line-height: 1.1;
}

.stat-value.sleep-value {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 36rpx;
}

.goal-check {
  width: 24rpx;
  height: 24rpx;
}

.stat-value.temp-value {
  transition: color 0.3s ease;
}

/* v4.0: 单位行（替代原 stat-label） */
.stat-unit {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

/* v4.0: 辅助行精简为 1 行 */
.stat-detail {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

/* v4.0: 进度条 */
.stat-progress {
  width: 100%;
  height: 4rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-pill);
  overflow: hidden;
  margin-top: auto;
}

.stat-progress-fill {
  height: 100%;
  border-radius: var(--radius-pill);
  animation: progressGrow 600ms ease-out forwards;
}

.stat-progress-fill.feeding { background: var(--feeding-color); }
.stat-progress-fill.sleep { background: var(--sleep-color); }
.stat-progress-fill.diaper { background: var(--diaper-color); }

.stat-progress-placeholder {
  width: 100%;
  height: 4rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-pill);
  margin-top: auto;
}

/* ============ v4.0 区域 E: 今日待办（竖向条） ============ */
.todo-list-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.todo-row {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  position: relative;
  border-bottom: 1rpx solid var(--border-color);
}

.todo-row:last-child {
  border-bottom: none;
}

.todo-row-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
}

.todo-row-bar.vaccine { background: var(--warning-color); }
.todo-row-bar.milestone { background: var(--info-color); }
.todo-row-bar.overdue { background: var(--danger-color); }

.todo-row-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-left: 8rpx;
}

.todo-row-text {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.todo-row-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-row-sub {
  font-size: 22rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.todo-row-tag {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.tag-overdue {
  color: var(--danger-color);
  background: rgba(232, 84, 84, 0.10);
}

.tag-upcoming {
  color: var(--warning-color);
  background: rgba(212, 136, 61, 0.10);
}

.todo-view-all {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 72rpx;
  border-top: 1rpx solid var(--border-color);
}

.todo-view-all text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--primary-color);
}

/* ============ FR-8/9: 快捷入口（横向滚动） ============ */
/* 标题区域 */
.quick-section {
  margin-bottom: 0;
}

.quick-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/*
 * 完全对齐记录页 .filters 的结构：
 * scroll-view 作为 content-container 的直接子元素，
 * 用负margin突破外层 .container 的 padding: 32rpx，
 * 让 scroll-view 撑满整个屏幕宽度，确保横向滚动无冲突。
 * 自身带背景色和圆角模拟卡片视觉。
 */
.quick-scroll {
  display: block;
  width: 100%;
  margin-bottom: 24rpx;
  padding: 24rpx 0;
  white-space: nowrap;
  background: var(--bg-secondary);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 123, 107, 0.08);
  box-sizing: border-box;
}

.quick-scroll-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.action-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  padding: 24rpx 12rpx;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(139, 123, 107, 0.15);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  flex-shrink: 0;
}

/* FR-8: 喂养预测角标 */
.action-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  font-weight: 500;
  z-index: 1;
}

.action-badge.prediction {
  background: var(--badge-prediction-bg);
  color: var(--text-primary, #3D3D3D);
}

.action-badge.urgent {
  background: var(--badge-urgent-bg);
  color: var(--white, #FFFFFF);
}

/* 功能色按钮 - 美拉德色系 */
.action-btn.feeding {
  background: linear-gradient(135deg, var(--feeding-color) 0%, var(--feeding-btn-end) 100%);
}

.action-btn.sleep {
  background: linear-gradient(135deg, var(--sleep-color) 0%, var(--sleep-btn-end) 100%);
}

/* FR-10: 睡眠计时中状态（脉冲动画） */
.action-btn.sleep.timing {
  background: linear-gradient(135deg, var(--sleep-timing-start) 0%, var(--sleep-timing-end) 100%);
  animation: sleepPulse 2s ease-in-out infinite;
}

@keyframes sleepPulse {
  0%, 100% {
    box-shadow: 0 4rpx 16rpx rgba(139, 123, 107, 0.15);
  }
  50% {
    box-shadow: 0 4rpx 24rpx rgba(184, 168, 212, 0.5);
  }
}

/* FR-10: 睡眠异常状态（>24h） */
.action-btn.sleep.abnormal {
  background: linear-gradient(135deg, var(--sleep-abnormal-start) 0%, var(--sleep-abnormal-end) 100%);
}

/* FR-10: 计时指示器（呼吸灯效果） */
.timing-indicator {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
}

.timing-dot {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--white, #FFFFFF);
  animation: timingBreathe 1.5s ease-in-out infinite;
}

@keyframes timingBreathe {
  0%, 100% {
    opacity: 0.4;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

.action-btn.diaper {
  background: linear-gradient(135deg, var(--diaper-color) 0%, var(--diaper-btn-end) 100%);
}

.action-btn.temperature {
  background: linear-gradient(135deg, var(--temperature-color) 0%, var(--temperature-btn-end) 100%);
}

/* FR-9: 生长按钮 */
.action-btn.growth {
  background: linear-gradient(135deg, var(--growth-btn-start) 0%, var(--growth-btn-end) 100%);
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(139, 123, 107, 0.2);
}

.action-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.action-text {
  font-size: 24rpx;
  color: var(--white);
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  line-height: 1;
  display: block;
}

/* ============ v4.0 区域 F: AI 洞察一行式 ============ */
.insight-v4 {
  margin-bottom: 20rpx;
  overflow: hidden;
  transition: all 0.3s ease;
}

/* 收起态 */
.insight-v4.insight-collapsed {
  height: 64rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-md);
}

/* 展开态 */
.insight-v4.insight-expanded {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.insight-v4-compact {
  display: flex;
  align-items: center;
  height: 64rpx;
  padding: 0 24rpx;
}

.insight-v4-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.insight-v4-summary {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.insight-v4-arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
  opacity: 0.5;
}

.insight-v4-arrow-up {
  transform: rotate(180deg);
}

.insight-v4-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 12rpx;
}

.insight-v4-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.insight-v4-badge {
  font-size: 20rpx;
  color: var(--text-hint);
  background: rgba(212, 184, 150, 0.2);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
}

.insight-v4-body {
  padding: 0 24rpx 20rpx;
}

.insight-v4-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  display: block;
}

.insight-v4-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  margin-top: 16rpx;
}

.insight-v4-action text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* ============ 家庭协作：Viewer 权限提示条 ============ */
.viewer-hint-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: rgba(212, 184, 150, 0.08);
  border: 1rpx solid rgba(212, 184, 150, 0.2);
  border-radius: 16rpx;
}

.viewer-hint-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
  flex-shrink: 0;
}

.viewer-hint-text {
  font-size: 24rpx;
  color: var(--text-hint, #A09080);
  line-height: 1.4;
}

/* ============ FR-11/12: 时间线增强 ============ */
.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.timeline-header .title {
  margin-bottom: 0;
}

.timeline-count {
  font-size: 24rpx;
  color: var(--text-hint, #A09080);
}

/* FR-12: 查看全部按钮 */
.view-all-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(212, 184, 150, 0.2);
}

.view-all-btn text {
  font-size: 26rpx;
  color: var(--primary-color, #D4B896);
  font-weight: 500;
}

.view-all-btn:active {
  opacity: 0.8;
}

.view-all-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

/* 时间线卡片 */
.timeline-card {
  padding: 32rpx 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 32rpx;
}

.add-baby-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, var(--primary-color, #D4B896) 0%, var(--primary-dark, #8B7B6B) 100%);
  color: var(--white);
  font-size: 28rpx;
  border-radius: 48rpx;
  border: none;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--primary-light, #E8DCC8);
  border-top-color: var(--primary-color, #D4B896);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ============ 彩蛋提示条（EE-5/EE-7） ============ */
.egg-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  background: rgba(212, 184, 150, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 184, 150, 0.15);
}

.egg-banner-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.egg-banner-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary, #3D3D3D);
  font-weight: 500;
}

.egg-banner-close {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.egg-banner-close text {
  font-size: 32rpx;
  color: var(--text-hint, #999999);
  line-height: 1;
}

@keyframes eggSlideDown {
  from {
    opacity: 0;
    transform: translateY(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============ 暖夜模式局部变量覆盖 ============ */
.dark-mode {
  --status-sleeping-bg: rgba(148, 136, 180, 0.15);
  --status-feeding-bg:  rgba(124, 175, 124, 0.15);
  --status-default-bg:  rgba(212, 184, 150, 0.10);

  --insight-bg: linear-gradient(135deg, rgba(212, 184, 150, 0.08) 0%, rgba(30, 26, 22, 1) 100%);
  --insight-border: rgba(212, 184, 150, 0.12);

  --todo-vaccine-bg:    rgba(196, 120, 48, 0.12);
  --todo-milestone-bg:  rgba(107, 147, 185, 0.12);
  --todo-overdue-bg:    rgba(212, 72, 72, 0.12);

  --badge-prediction-bg: rgba(124, 175, 124, 0.8);
  --badge-urgent-bg:     var(--warning-color);

  --fever-alert-bg:     rgba(212, 72, 72, 0.10);
  --fever-alert-border: rgba(212, 72, 72, 0.25);
  --fever-alert-text:   var(--danger-color);

  --skeleton-base: rgba(212, 184, 150, 0.06);
  --skeleton-highlight: rgba(212, 184, 150, 0.12);
}
