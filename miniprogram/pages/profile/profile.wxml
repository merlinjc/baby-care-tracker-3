<view class="container page-enter {{darkMode ? 'dark-mode' : ''}}">
  <!-- v4.0: 用户信息 — 居中头像 + 角色 pill -->
  <view class="user-section" bindtap="editProfile">
    <image 
      class="user-avatar"
      src="{{userInfo.avatar || '/images/default-avatar.svg'}}"
      mode="aspectFill"
    />
    <view class="user-name">{{userInfo.nickname || '未设置昵称'}}</view>
    <view class="user-role-pill">{{userInfo.role === 'parent' ? '家长' : '家庭成员'}}</view>
  </view>

  <!-- v4.0: 编辑个人资料弹窗（底部弹出） -->
  <view class="popup-mask {{showEditPopup ? 'popup-mask-visible' : ''}}" wx:if="{{showEditPopup}}" bindtap="closeEditPopup" catchtouchmove="preventTouchMove">
    <view class="popup-container {{showEditPopup ? 'popup-enter' : ''}}" catchtap="">
      <view class="swipe-indicator"></view>
      <view class="popup-header">
        <view class="popup-icon">
          <image src="/images/icons/edit-gray.png" mode="aspectFit" />
        </view>
        <text class="popup-title">编辑个人资料</text>
        <view class="popup-close" bindtap="closeEditPopup">
          <image src="/images/icons/x-mark.png" mode="aspectFit" />
        </view>
      </view>
      <scroll-view class="popup-content" scroll-y>
        <view class="popup-inner">
          <!-- 头像编辑 -->
          <view class="edit-avatar-section" bindtap="changeAvatar">
            <image 
              class="edit-avatar"
              src="{{editAvatar || '/images/default-avatar.svg'}}"
              mode="aspectFill"
            />
            <view class="edit-avatar-overlay">
              <image class="camera-icon" src="/images/icons/camera-white.png" mode="aspectFit"></image>
            </view>
            <text class="edit-avatar-hint">点击更换头像</text>
          </view>
          <!-- 昵称编辑 -->
          <view class="edit-field">
            <text class="edit-field-label">昵称</text>
            <input 
              class="edit-input"
              value="{{editNickname}}"
              placeholder="请输入昵称"
              maxlength="12"
              bindinput="onNicknameInput"
            />
          </view>
          <!-- 保存按钮 -->
          <view class="submit-btn" bindtap="saveProfile">保存</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 家庭信息卡片 - 温馨的家庭展示 -->
  <view class="card family-card card-stagger" wx:if="{{familyInfo}}" bindtap="goToFamily">
    <view class="family-header">
      <view class="family-icon-wrapper">
        <image class="family-icon" src="/images/icons/family.png" mode="aspectFit"></image>
      </view>
      <view class="family-content">
        <view class="family-name">{{familyInfo.name}}</view>
        <view class="family-members">{{familyInfo.members.length}} 位成员</view>
      </view>
      <image class="arrow-icon" src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load></image>
    </view>
    <view class="family-avatars" wx:if="{{familyInfo.members.length > 1}}">
      <image 
        class="member-avatar" 
        wx:for="{{familyInfo.members}}" 
        wx:key="userId"
        wx:if="{{index < 5}}"
        src="{{item.avatarUrl || '/images/default-avatar.svg'}}"
        mode="aspectFill"
        lazy-load
      ></image>
      <view class="member-more" wx:if="{{familyInfo.members.length > 5}}">
        +{{familyInfo.members.length - 5}}
      </view>
    </view>
  </view>

  <!-- v4.0: 功能菜单 — 去描述，精简 -->
  <view class="card menu-card card-stagger">
    <view class="menu-section">
      <view
        class="menu-item"
        wx:for="{{menuItems}}"
        wx:key="title"
        data-url="{{item.url}}"
        bindtap="goToPage"
      >
        <view class="menu-icon-wrapper {{item.bgClass}}">
          <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" lazy-load></image>
        </view>
        <text class="menu-title">{{item.title}}</text>
        <view class="menu-arrow">
          <image src="/images/icons/arrow-right.png" mode="aspectFit" lazy-load></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出使用 - 彻底清除用户数据 -->
  <view class="logout-btn card-stagger" bindtap="logout">
    <image class="logout-icon" src="/images/icons/close.png" mode="aspectFit" lazy-load></image>
    <text>退出使用</text>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>Baby Care Tracker v4.0.0</text>
  </view>
</view>
