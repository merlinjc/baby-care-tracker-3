/* 个人中心 - 美拉德色彩风格优化版 */

/* ========== 用户卡片 ========== */
.user-card {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.08) 0%, 
    rgba(232, 220, 200, 0.15) 100%
  );
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(212, 184, 150, 0.2);
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(212, 184, 150, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.user-header {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  margin-right: 32rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  box-shadow: var(--shadow-card);
  border: 4rpx solid var(--bg-secondary);
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.user-role {
  display: flex;
  align-items: center;
}

.role-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, 
    rgba(184, 212, 184, 0.2) 0%, 
    rgba(168, 212, 168, 0.25) 100%
  );
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--role-badge-color, #6B8B6B);
  font-weight: 500;
  border: 1rpx solid rgba(184, 212, 184, 0.3);
}

.user-actions {
  margin-left: 16rpx;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.6;
  transition: all 0.3s ease;
}

.action-icon:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* ========== 家庭卡片 ========== */
.family-card {
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-normal);
}

.family-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.1);
}

.family-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.family-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.15) 0%, 
    rgba(196, 149, 106, 0.2) 100%
  );
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.family-icon {
  width: 40rpx;
  height: 40rpx;
}

.family-content {
  flex: 1;
}

.family-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.family-members {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.family-avatars {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  margin-right: -8rpx;
  border: 3rpx solid var(--white);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
}

.member-more {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(139, 123, 107, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-left: 8rpx;
}

/* ========== 功能菜单卡片 ========== */
.menu-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 8rpx 0;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.menu-section {
  padding: 0 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  margin-bottom: 0;
}

.menu-item:active {
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.08) 0%, 
    rgba(232, 220, 200, 0.12) 100%
  );
  transform: scale(0.98);
}

.menu-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  transition: all 0.3s ease;
}

/* 菜单图标背景色 - 美拉德色系 */
.menu-icon-wrapper.bg-baby {
  background: linear-gradient(135deg, 
    rgba(168, 212, 168, 0.2) 0%, 
    rgba(152, 196, 152, 0.25) 100%
  );
}

.menu-icon-wrapper.bg-family {
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.2) 0%, 
    rgba(196, 149, 106, 0.25) 100%
  );
}

.menu-icon-wrapper.bg-stats {
  background: linear-gradient(135deg, 
    rgba(212, 200, 168, 0.2) 0%, 
    rgba(196, 180, 140, 0.25) 100%
  );
}

.menu-icon-wrapper.bg-settings {
  background: linear-gradient(135deg, 
    rgba(184, 196, 212, 0.2) 0%, 
    rgba(168, 180, 196, 0.25) 100%
  );
}

.menu-icon-wrapper.bg-help {
  background: linear-gradient(135deg, 
    rgba(196, 212, 184, 0.2) 0%, 
    rgba(180, 196, 168, 0.25) 100%
  );
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.3;
}

.menu-arrow {
  margin-left: 16rpx;
}

.menu-arrow image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

/* ========== 退出使用按钮 ========== */
.logout-btn {
  margin-top: 48rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--logout-text, #D48B8B);
  font-weight: 500;
  background: linear-gradient(135deg, 
    rgba(212, 139, 139, 0.05) 0%, 
    rgba(196, 123, 123, 0.08) 100%
  );
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 139, 139, 0.15);
  transition: all var(--transition-normal);
  gap: 12rpx;
}

.logout-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, 
    rgba(212, 139, 139, 0.1) 0%, 
    rgba(196, 123, 123, 0.15) 100%
  );
}

.logout-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.8;
  display: block;
  flex-shrink: 0;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 48rpx 0 32rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  opacity: 0.6;
}

/* ========== 编辑个人资料弹窗 ========== */
.edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-popup {
  width: 580rpx;
  background: var(--bg-card, #FFFFFF);
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.edit-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 36rpx;
}

/* 头像编辑区域 */
.edit-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
  position: relative;
}

.edit-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 4rpx solid var(--border-color, rgba(212, 184, 150, 0.3));
}

.edit-avatar-overlay {
  position: absolute;
  top: 0;
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  width: 44rpx;
  height: 44rpx;
}

.edit-avatar-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

/* 字段编辑区域 */
.edit-field {
  margin-bottom: 8rpx;
}

.edit-field-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color, rgba(212, 184, 150, 0.3));
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: var(--bg-primary, #FFF8F0);
  box-sizing: border-box;
}

.edit-popup-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.edit-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all var(--transition-fast, 0.15s);
}

.edit-btn:active {
  transform: scale(0.97);
}

.edit-btn.cancel {
  background: var(--bg-secondary, #F5F0E8);
  color: var(--text-secondary);
}

.edit-btn.confirm {
  background: var(--primary, #D4B896);
  color: #FFFFFF;
}
