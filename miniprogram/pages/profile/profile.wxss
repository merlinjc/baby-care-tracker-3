/* 个人中心 - v4.0 重构 */
@import '../../styles/popup.wxss';
@import '../../styles/form.wxss';

/* ========== v4.0 用户信息区 — 居中 ========== */
.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid var(--primary-color);
  box-shadow: var(--elevation-2);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 16rpx;
}

.user-role-pill {
  display: inline-block;
  padding: 6rpx 20rpx;
  margin-top: 10rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 500;
  color: var(--primary-dark);
  background: rgba(212, 184, 150, 0.10);
}

/* ========== 家庭卡片（保留） ========== */
.family-card {
  padding: 32rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  transition: all var(--transition-normal);
}

.family-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 16rpx rgba(139, 123, 107, 0.1);
}

.family-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.family-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, 
    rgba(212, 184, 150, 0.15) 0%, 
    rgba(196, 149, 106, 0.2) 100%
  );
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.family-icon {
  width: 40rpx;
  height: 40rpx;
}

.family-content {
  flex: 1;
}

.family-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.family-members {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

.family-avatars {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  margin-right: -8rpx;
  border: 3rpx solid var(--white);
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
}

.member-more {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(139, 123, 107, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-left: 8rpx;
}

/* ========== v4.0 功能菜单 — 去描述，精简 ========== */
.menu-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 8rpx 0;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.menu-section {
  padding: 0 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  margin-bottom: 4rpx;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  margin-bottom: 0;
}

.menu-item:active {
  background: rgba(212, 184, 150, 0.08);
  transform: scale(0.98);
}

.menu-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

/* 菜单图标背景色 */
.menu-icon-wrapper.bg-baby {
  background: linear-gradient(135deg, rgba(168, 212, 168, 0.2), rgba(152, 196, 152, 0.25));
}
.menu-icon-wrapper.bg-family {
  background: linear-gradient(135deg, rgba(212, 184, 150, 0.2), rgba(196, 149, 106, 0.25));
}
.menu-icon-wrapper.bg-stats {
  background: linear-gradient(135deg, rgba(212, 200, 168, 0.2), rgba(196, 180, 140, 0.25));
}
.menu-icon-wrapper.bg-settings {
  background: linear-gradient(135deg, rgba(184, 196, 212, 0.2), rgba(168, 180, 196, 0.25));
}
.menu-icon-wrapper.bg-help {
  background: linear-gradient(135deg, rgba(196, 212, 184, 0.2), rgba(180, 196, 168, 0.25));
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.menu-arrow {
  margin-left: 16rpx;
}

.menu-arrow image {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

/* ========== 退出使用按钮 ========== */
.logout-btn {
  margin-top: 48rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--logout-text, #D48B8B);
  font-weight: 500;
  background: linear-gradient(135deg, rgba(212, 139, 139, 0.05), rgba(196, 123, 123, 0.08));
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 139, 139, 0.15);
  transition: all var(--transition-normal);
  gap: 12rpx;
}

.logout-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(212, 139, 139, 0.1), rgba(196, 123, 123, 0.15));
}

.logout-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.8;
  display: block;
  flex-shrink: 0;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 48rpx 0 32rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  opacity: 0.6;
}

/* ========== v4.0 编辑弹窗内容样式 ========== */
.edit-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
  position: relative;
}

.edit-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color);
}

.edit-avatar-overlay {
  position: absolute;
  top: 0;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  width: 36rpx;
  height: 36rpx;
}

.edit-avatar-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

.edit-field {
  margin-bottom: 8rpx;
}

.edit-field-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  background: var(--bg-primary);
  box-sizing: border-box;
}
