/**
 * WXS 格式化工具函数
 * 在视图层直接执行，避免逻辑层-视图层通信开销
 * 
 * 注意：WXS 不支持 ES6+ 语法，使用 ES5 编写
 */

/**
 * 格式化时长显示（毫秒 -> Xh Xm / Xm）
 * @param {number} ms - 毫秒数
 * @returns {string} 格式化后的时长字符串
 */
function formatDuration(ms) {
  if (!ms || ms <= 0) return '0m';
  
  var totalMinutes = Math.floor(ms / 60000);
  var hours = Math.floor(totalMinutes / 60);
  var minutes = totalMinutes % 60;
  
  if (hours > 0) {
    return minutes > 0 ? hours + 'h ' + minutes + 'm' : hours + 'h';
  }
  return minutes + 'm';
}

/**
 * 格式化时长显示（秒 -> X小时X分钟 / X分钟）
 * @param {number} seconds - 秒数
 * @returns {string} 格式化后的时长字符串（中文）
 */
function formatDurationCN(seconds) {
  if (!seconds || seconds <= 0) return '0分钟';
  
  var totalMinutes = Math.floor(seconds / 60);
  var hours = Math.floor(totalMinutes / 60);
  var minutes = totalMinutes % 60;
  
  if (hours > 0) {
    return minutes > 0 ? hours + '小时' + minutes + '分钟' : hours + '小时';
  }
  return minutes + '分钟';
}

/**
 * 格式化温度显示
 * @param {number} value - 温度值
 * @returns {string} 格式化后的温度字符串
 */
function formatTemp(value) {
  if (value === null || value === undefined) return '--';
  return value + '°C';
}

/**
 * 格式化数字显示（保留1位小数，去掉末尾0）
 * @param {number} value - 数值
 * @param {number} digits - 小数位数，默认 1
 * @returns {string} 格式化后的数字字符串
 */
function formatNumber(value, digits) {
  if (value === null || value === undefined) return '--';
  var d = digits !== undefined ? digits : 1;
  var num = value * 1;
  var factor = Math.pow(10, d);
  var rounded = Math.round(num * factor) / factor;
  var str = '' + rounded;
  // 如果需要小数但结果是整数，补上小数点和0
  var dotIndex = str.indexOf('.');
  if (d > 0 && dotIndex === -1) {
    str = str + '.';
    dotIndex = str.length - 1;
  }
  // 补足小数位数
  if (d > 0) {
    var currentDecimals = str.length - dotIndex - 1;
    for (var i = currentDecimals; i < d; i++) {
      str = str + '0';
    }
  }
  // 去掉末尾的0和多余小数点
  if (d > 0) {
    while (str.charAt(str.length - 1) === '0') {
      str = str.substring(0, str.length - 1);
    }
    if (str.charAt(str.length - 1) === '.') {
      str = str.substring(0, str.length - 1);
    }
  }
  return str;
}

module.exports = {
  formatDuration: formatDuration,
  formatDurationCN: formatDurationCN,
  formatTemp: formatTemp,
  formatNumber: formatNumber
};
