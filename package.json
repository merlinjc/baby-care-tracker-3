{
  "name": "baby-care-tracker-web",
  "version": "1.0.0",
  "private": true,
  "description": "Baby Care Tracker Web 版 - 前后端单体架构",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm build:server && pnpm build:client",
    "build:client": "pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:push": "pnpm --filter server db:push",
    "db:studio": "pnpm --filter server db:studio",
    "lint": "pnpm --filter client lint",
    "docker:build": "docker build -f docker/Dockerfile --target runtime -t baby-care-tracker-web:local . && docker build -f docker/Dockerfile --target client-dist -t baby-care-tracker-web:local-client .",
    "docker:up": "docker compose --env-file docker/.env -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose --env-file docker/.env -f docker/docker-compose.yml down",
    "docker:logs": "docker compose --env-file docker/.env -f docker/docker-compose.yml logs -f",
    "deploy": "bash scripts/deploy.sh",
    "deploy:fast": "FAST=1 bash scripts/deploy.sh",
    "remote": "bash scripts/remote.sh",
    "server:bootstrap": "bash scripts/server-bootstrap.sh",
    "test:api": "pnpm --filter server test",
    "test:e2e:seed": "pnpm --filter server db:seed:e2e",
    "test:e2e:bulk": "pnpm --filter server db:seed:e2e:bulk",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.0"
  },
  "keywords": [
    "baby",
    "care",
    "tracker"
  ],
  "license": "MIT"
}
