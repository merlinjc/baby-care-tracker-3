# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/baby_care

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AI (OpenAI 兼容，默认：TokenHub · hy3-preview)
# 未配置 OPENAI_API_KEY 时 AI 功能自动降级为 mock / 本地规则引擎
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_MODEL=hy3-preview
AI_DAILY_QUOTA=100
AI_FETCH_TIMEOUT_MS=30000
