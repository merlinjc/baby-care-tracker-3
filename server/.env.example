# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/baby_care

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AI (OpenAI 兼容，默认：TokenHub · hy3-preview)
# 未配置 OPENAI_API_KEY 时 AI 功能自动降级为 mock / 本地规则引擎
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_MODEL=hy3-preview
AI_DAILY_QUOTA=100
AI_FETCH_TIMEOUT_MS=30000

# 腾讯云 COS 对象存储（v7.2 T-S1-INF-02）
# 用于头像 / 每日打卡照片等图片上传；任一字段缺失时 /api/uploads/presign 返回 503，
# 前端 ImageUploader 优雅降级，主流程不阻塞。
# 申请：https://console.cloud.tencent.com/cos
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=baby-care-xxxxxxx
COS_REGION=ap-shanghai
# 可选：CDN 公开访问基础 URL（不填则用默认 COS 域名）
# COS_PUBLIC_BASE_URL=https://cdn.example.com
# presign 有效期（秒），默认 300（5 分钟），范围 60-3600
COS_PRESIGN_EXPIRES=300
