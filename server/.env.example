# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://root:password@localhost:3306/baby_care

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AI (OpenAI 兼容，默认：TokenHub · hy3-preview)
# 未配置 OPENAI_API_KEY 时 AI 功能自动降级为 mock / 本地规则引擎
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_MODEL=hy3-preview
AI_DAILY_QUOTA=100
AI_FETCH_TIMEOUT_MS=30000

# 腾讯云 COS 对象存储（v7.2 T-S1-INF-02 服务端代理模式）
# 用于头像 / 每日打卡照片上传与下载；任一字段缺失时 /api/uploads 返回 503，
# 前端 ImageUploader 优雅降级，主流程不阻塞。
# 桶设为「私有读私有写」：所有读写经服务端代理，密钥不暴露给客户端。
# 申请：https://console.cloud.tencent.com/cos
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=babycare-xxxxxxxxxx
COS_REGION=ap-beijing
# 服务端 putObject 单文件最大字节数（multer + service 双层校验），默认 2MB
COS_MAX_UPLOAD_BYTES=2097152
# 下载代理响应的 Cache-Control max-age（秒），默认 86400（1 天）；设 0 禁用缓存
COS_DOWNLOAD_CACHE_MAX_AGE=86400
