{
  "name": "@baby-care-tracker/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:e2e": "tsx prisma/seed-e2e.ts --reset",
    "db:seed:e2e:bulk": "tsx prisma/seed-e2e.ts --reset --bulk=5000",
    "db:seed:e2e:json": "tsx prisma/seed-e2e.ts --reset --json",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:setup": "DATABASE_URL=\"file:./test.db\" prisma db push --skip-generate --force-reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^6.7.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.12.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
